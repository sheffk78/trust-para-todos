# ── Required ────────────────────────────────────────
DATABASE_URL="postgres://user:pass@host:5432/trust_para_todos"
ADMIN_PASSWORD="change-this-in-production"
AUTH_SECRET="change-this-to-a-random-secret"

# ── Optional ───────────────────────────────────────
# Set to proxy /api/* to a separate backend service
# BACKEND_URL="https://your-backend.railway.app"

# Stripe (for checkout)
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_PRICE_BASE_ID="price_..."
# STRIPE_PRICE_COMPLETO_ID="price_..."

# Brevo (for email)
# BREVO_API_KEY="..."
