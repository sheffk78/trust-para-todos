# Trust Para Todos — Backend Environment Variables
# Copy this file to `.env` and fill in real values.
# In production, set these as Railway service variables.

# ---- App ----
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ---- Database ----
# Local dev (SQLite — no Postgres needed):
DATABASE_URL=sqlite+aiosqlite:///./trust_para_todos.db
# Production (Railway auto-injects this when you link a Postgres service):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ---- Stripe ----
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_replace_me
# Get from Stripe dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_replace_me
# Create products/prices in Stripe dashboard, then paste the price IDs here:
STRIPE_PRICE_BASE_ID=price_replace_me_base
STRIPE_PRICE_COMPLETO_ID=price_replace_me_completo

# ---- Brevo (Sendinblue) ----
# Get from https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeys-brevo-replace-me
BREVO_SENDER_EMAIL=hola@trustparatodos.com
BREVO_SENDER_NAME=Trust Para Todos
# Brevo transactional template IDs — create templates in Brevo, paste IDs here:
BREVO_TEMPLATE_WELCOME=1
BREVO_TEMPLATE_NOTARY_REMINDER=2
BREVO_TEMPLATE_COURSE_INVITE=3
BREVO_TEMPLATE_DOCUMENTS_READY=4
BREVO_TEMPLATE_NEXT_STEPS=5
BREVO_TEMPLATE_INSURANCE_OFFER=6
BREVO_TEMPLATE_LEAD_DAY_0=7
BREVO_TEMPLATE_LEAD_DAY_1=8
BREVO_TEMPLATE_LEAD_DAY_2=9
BREVO_TEMPLATE_LEAD_DAY_3=10
BREVO_TEMPLATE_LEAD_DAY_5=11

# ---- Frontend / CORS ----
FRONTEND_URL=http://localhost:4321
CORS_ORIGINS=http://localhost:4321,http://localhost:3000,https://trust-para-todos-production.up.railway.app,https://trustparatodos.com,https://www.trustparatodos.com

# ---- Auth (stub) ----
AUTH_SECRET=change-me-in-production
AUTH_CODE_TTL_SECONDS=600

# ---- Pricing (mirror frontend; for server-side validation) ----
PLAN_BASE_PRICE_CENTS=99700
PLAN_COMPLETO_PRICE_CENTS=149400

# ---- File storage ----
DOCUMENTS_DIR=./generated_documents