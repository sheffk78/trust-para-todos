---
export interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props;
import '../styles/global.css';
import { getLocaleFromCookie } from '../lib/i18n';
const locale = getLocaleFromCookie(Astro.request.headers.get('cookie'));
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Trust Para Todos Admin</title>
    <meta name="description" content={description || 'Admin portal'} />
    <link rel="icon" type="image/svg+xml" href="/assets/logo-shield.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <style>
      .admin-layout { display: flex; min-height: 100vh; }
      
      /* Sidebar */
      .admin-sidebar {
        width: 240px;
        background: var(--dark);
        color: rgba(255,255,255,0.8);
        display: flex;
        flex-direction: column;
        flex-shrink: 0;
      }
      .admin-sidebar-header {
        padding: 24px 20px;
        border-bottom: 1px solid rgba(255,255,255,0.08);
      }
      .admin-sidebar-header h2 {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 1.1rem;
        color: var(--white);
        margin: 0;
      }
      .admin-sidebar-header p {
        font-size: 0.75rem;
        color: rgba(255,255,255,0.4);
        margin-top: 2px;
      }
      .admin-nav { padding: 12px 0; flex: 1; }
      .admin-nav a {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 20px;
        color: rgba(255,255,255,0.6);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        transition: all 0.2s;
        border-left: 3px solid transparent;
      }
      .admin-nav a:hover { color: var(--white); background: rgba(255,255,255,0.05); }
      .admin-nav a.active {
        color: var(--white);
        background: rgba(255,255,255,0.08);
        border-left-color: var(--terracotta);
      }
      .admin-nav a .nav-icon { font-size: 1.1rem; width: 20px; text-align: center; }
      .admin-sidebar-footer {
        padding: 16px 20px;
        border-top: 1px solid rgba(255,255,255,0.08);
        font-size: 0.8rem;
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      .admin-sidebar-footer a, .admin-sidebar-footer button {
        color: rgba(255,255,255,0.4);
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 8px;
        background: none;
        border: none;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.8rem;
        padding: 0;
        text-align: left;
      }
      .admin-sidebar-footer a:hover, .admin-sidebar-footer button:hover { color: var(--white); }
      .logout-btn { color: rgba(221,112,84,0.6) !important; }
      .logout-btn:hover { color: var(--terracotta) !important; }

      /* Language toggle */
      .lang-toggle {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 6px 12px;
        background: var(--cream);
        border: 1px solid var(--cream-dark);
        border-radius: 100px;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--dark);
        transition: all 0.2s;
        white-space: nowrap;
      }
      .lang-toggle:hover {
        background: var(--cream-dark);
        transform: translateY(-1px);
      }

      /* Mobile sidebar overlay */
      .mobile-sidebar-toggle {
        display: none;
        background: none;
        border: none;
        font-size: 1.5rem;
        cursor: pointer;
        color: var(--dark);
        padding: 4px;
      }
      .sidebar-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        z-index: 200;
      }
      .sidebar-overlay.open { display: block; }
      .mobile-sidebar {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        bottom: 0;
        width: 280px;
        background: var(--dark);
        z-index: 201;
        transform: translateX(-100%);
        transition: transform 0.3s ease;
        flex-direction: column;
      }
      .mobile-sidebar.open { transform: translateX(0); }

      /* Main content */
      .admin-main {
        flex: 1;
        background: var(--cream);
        display: flex;
        flex-direction: column;
        min-width: 0;
      }
      .admin-topbar {
        background: var(--white);
        border-bottom: 1px solid var(--cream-dark);
        padding: 16px 32px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
      }
      .admin-topbar h1 {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 1.3rem;
        color: var(--dark);
        margin: 0;
        flex: 1;
      }
      .admin-content { padding: 32px; flex: 1; }

      @media (max-width: 768px) {
        .admin-sidebar { display: none; }
        .mobile-sidebar-toggle { display: block; }
        .mobile-sidebar { display: flex; }
        .admin-topbar { padding: 12px 16px; }
        .admin-content { padding: 16px; }
      }
    </style>

    <!-- Desktop sidebar -->
    <div class="admin-layout">
      <aside class="admin-sidebar">
        <div class="admin-sidebar-header">
          <h2>Trust Para Todos</h2>
          <p data-i18n="nav.admin_panel">Panel de Administración</p>
        </div>
        <nav class="admin-nav">
          <a href="/admin" class:list={{ active: Astro.url.pathname === '/admin' }}>
            <span class="nav-icon">📊</span> <span data-i18n="nav.dashboard">Dashboard</span>
          </a>
          <a href="/admin/orders" class:list={{ active: Astro.url.pathname.startsWith('/admin/orders') }}>
            <span class="nav-icon">📋</span> <span data-i18n="nav.orders">Órdenes</span>
          </a>
          <a href="/admin/customers" class:list={{ active: Astro.url.pathname.startsWith('/admin/customers') }}>
            <span class="nav-icon">👥</span> <span data-i18n="nav.customers">Clientes</span>
          </a>
        </nav>
        <div class="admin-sidebar-footer">
          <a href="/"><span data-i18n="nav.back_to_site">← Volver al sitio</span></a>
          <a href="/api/admin/logout" class="logout-btn" style="cursor:pointer;">🚪 <span data-i18n="nav.logout">Cerrar Sesión</span></a>
        </div>
      </aside>

      <!-- Mobile sidebar overlay -->
      <div id="sidebar-overlay" class="sidebar-overlay" onclick="closeMobileSidebar()"></div>
      <aside id="mobile-sidebar" class="mobile-sidebar">
        <div class="admin-sidebar-header" style="display:flex; justify-content:space-between; align-items:center;">
          <div>
            <h2>Trust Para Todos</h2>
            <p data-i18n="nav.admin_panel">Panel de Administración</p>
          </div>
          <button onclick="closeMobileSidebar()" style="background:none; border:none; color:rgba(255,255,255,0.6); font-size:1.5rem; cursor:pointer;">✕</button>
        </div>
        <nav class="admin-nav">
          <a href="/admin" onclick="closeMobileSidebar()">
            <span class="nav-icon">📊</span> <span data-i18n="nav.dashboard">Dashboard</span>
          </a>
          <a href="/admin/orders" onclick="closeMobileSidebar()">
            <span class="nav-icon">📋</span> <span data-i18n="nav.orders">Órdenes</span>
          </a>
          <a href="/admin/customers" onclick="closeMobileSidebar()">
            <span class="nav-icon">👥</span> <span data-i18n="nav.customers">Clientes</span>
          </a>
        </nav>
        <div class="admin-sidebar-footer">
          <a href="/" onclick="closeMobileSidebar()"><span data-i18n="nav.back_to_site">← Volver al sitio</span></a>
          <a href="/api/admin/logout" class="logout-btn" style="cursor:pointer;">🚪 <span data-i18n="nav.logout">Cerrar Sesión</span></a>
        </div>
      </aside>

      <div class="admin-main">
        <div class="admin-topbar">
          <button class="mobile-sidebar-toggle" onclick="openMobileSidebar()" aria-label="Menú">☰</button>
          <h1>{title}</h1>
          <button class="lang-toggle" onclick="toggleLanguage()" id="lang-toggle">
            <span id="lang-icon">{locale === 'en' ? '🇲🇽' : '🇺🇸'}</span>
            <span id="lang-label">{locale === 'en' ? 'Español' : 'English'}</span>
          </button>
        </div>
        <div class="admin-content">
          <slot />
        </div>
      </div>
    </div>

    <script>
      const LOCALE = '{locale}';

      function toggleLanguage() {
        const newLang = LOCALE === 'es' ? 'en' : 'es';
        document.cookie = `tpt_lang=${newLang}; path=/; max-age=${60 * 60 * 24 * 365}; SameSite=Lax`;
        window.location.reload();
      }

      function openMobileSidebar() {
        document.getElementById('mobile-sidebar').classList.add('open');
        document.getElementById('sidebar-overlay').classList.add('open');
      }
      function closeMobileSidebar() {
        document.getElementById('mobile-sidebar').classList.remove('open');
        document.getElementById('sidebar-overlay').classList.remove('open');
      }
    </script>
  </body>
</html>
