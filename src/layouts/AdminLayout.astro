---
export interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props;
import '../styles/global.css';
import { getLocaleFromCookie, DICT } from '../lib/i18n';
const locale = getLocaleFromCookie(Astro.request.headers.get('cookie'));
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Trust Para Todos Admin</title>
    <meta name="description" content={description || 'Admin portal'} />
    <link rel="icon" type="image/svg+xml" href="/assets/logo-shield.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <style>
      .admin-layout { display: flex; min-height: 100vh; }
      
      /* Sidebar — dark teal, not pure black */
      .admin-sidebar {
        width: 240px;
        background: #0d2b2e;
        color: rgba(255,255,255,0.8);
        display: flex;
        flex-direction: column;
        flex-shrink: 0;
      }
      .admin-sidebar-header {
        padding: 24px 20px;
        border-bottom: 1px solid rgba(255,255,255,0.06);
      }
      .admin-sidebar-header h2 {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 1.1rem;
        color: var(--white);
        margin: 0;
      }
      .admin-sidebar-header p {
        font-size: 0.75rem;
        color: rgba(255,255,255,0.35);
        margin-top: 2px;
      }
      .admin-nav { padding: 8px 0; flex: 1; }
      .admin-nav a {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 20px;
        color: rgba(255,255,255,0.5);
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 500;
        transition: all 0.2s;
        border-left: 3px solid transparent;
      }
      .admin-nav a:hover { color: var(--white); background: rgba(255,255,255,0.04); }
      .admin-nav a.active {
        color: var(--white);
        background: rgba(255,255,255,0.06);
        border-left-color: var(--terracotta);
      }
      .admin-nav a .nav-icon { 
        width: 20px; 
        height: 20px; 
        display: flex; 
        align-items: center; 
        justify-content: center;
        opacity: 0.6;
      }
      .admin-nav a:hover .nav-icon,
      .admin-nav a.active .nav-icon { opacity: 1; }
      .admin-nav a .nav-icon svg { width: 18px; height: 18px; }
      .admin-sidebar-footer {
        padding: 16px 20px;
        border-top: 1px solid rgba(255,255,255,0.06);
        font-size: 0.8rem;
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      .admin-sidebar-footer a, .admin-sidebar-footer button {
        color: rgba(255,255,255,0.35);
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 8px;
        background: none;
        border: none;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.8rem;
        padding: 0;
        text-align: left;
      }
      .admin-sidebar-footer a:hover, .admin-sidebar-footer button:hover { color: var(--white); }
      .logout-btn { color: rgba(221,112,84,0.5) !important; }
      .logout-btn:hover { color: var(--terracotta) !important; }

      /* Language toggle */
      .lang-toggle {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 6px 12px;
        background: var(--cream);
        border: 1px solid var(--cream-dark);
        border-radius: 100px;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--dark);
        transition: all 0.2s;
        white-space: nowrap;
      }
      .lang-toggle:hover {
        background: var(--cream-dark);
        transform: translateY(-1px);
      }

      /* Mobile sidebar overlay */
      .mobile-sidebar-toggle {
        display: none;
        background: none;
        border: none;
        font-size: 1.5rem;
        cursor: pointer;
        color: var(--dark);
        padding: 4px;
      }
      .sidebar-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        z-index: 200;
      }
      .sidebar-overlay.open { display: block; }
      .mobile-sidebar {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        bottom: 0;
        width: 280px;
        background: #0d2b2e;
        z-index: 201;
        transform: translateX(-100%);
        transition: transform 0.3s ease;
        flex-direction: column;
      }
      .mobile-sidebar.open { transform: translateX(0); }

      /* Main content */
      .admin-main {
        flex: 1;
        background: #faf5ed;
        display: flex;
        flex-direction: column;
        min-width: 0;
      }
      .admin-topbar {
        background: #ffffff;
        border-bottom: 1px solid #e8e4d8;
        padding: 16px 32px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
      }
      .admin-topbar h1 {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 1.3rem;
        color: #1a1a1a;
        margin: 0;
        flex: 1;
      }
      .admin-content { padding: 32px; flex: 1; }

      @media (max-width: 768px) {
        .admin-sidebar { display: none; }
        .mobile-sidebar-toggle { display: block; }
        .mobile-sidebar { display: flex; }
        .admin-topbar { padding: 12px 16px; }
        .admin-content { padding: 16px; }
      }
    </style>

    <!-- Desktop sidebar -->
    <div class="admin-layout">
      <aside class="admin-sidebar">
        <div class="admin-sidebar-header">
          <h2>Trust Para Todos</h2>
          <p data-i18n="nav.admin_panel">Panel de Administración</p>
        </div>
        <nav class="admin-nav">
          <a href="/admin" class:list={{ active: Astro.url.pathname === '/admin' }}>
            <span class="nav-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
              </svg>
            </span>
            <span data-i18n="nav.dashboard">Dashboard</span>
          </a>
          <a href="/admin/orders" class:list={{ active: Astro.url.pathname.startsWith('/admin/orders') }}>
            <span class="nav-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>
              </svg>
            </span>
            <span data-i18n="nav.orders">Órdenes</span>
          </a>
          <a href="/admin/customers" class:list={{ active: Astro.url.pathname.startsWith('/admin/customers') }}>
            <span class="nav-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            </span>
            <span data-i18n="nav.customers">Clientes</span>
          </a>
        </nav>
        <div class="admin-sidebar-footer">
          <a href="/">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px;">
              <polyline points="15 18 9 12 15 6"/>
            </svg>
            <span data-i18n="nav.back_to_site">Volver al sitio</span>
          </a>
          <a href="/api/admin/logout" class="logout-btn" style="cursor:pointer;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px;">
              <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
            <span data-i18n="nav.logout">Cerrar Sesión</span>
          </a>
        </div>
      </aside>

      <!-- Mobile sidebar overlay -->
      <div id="sidebar-overlay" class="sidebar-overlay" onclick="closeMobileSidebar()"></div>
      <aside id="mobile-sidebar" class="mobile-sidebar">
        <div class="admin-sidebar-header" style="display:flex; justify-content:space-between; align-items:center;">
          <div>
            <h2>Trust Para Todos</h2>
            <p data-i18n="nav.admin_panel">Panel de Administración</p>
          </div>
          <button onclick="closeMobileSidebar()" style="background:none; border:none; color:rgba(255,255,255,0.6); font-size:1.5rem; cursor:pointer;">✕</button>
        </div>
        <nav class="admin-nav">
          <a href="/admin" onclick="closeMobileSidebar()">
            <span class="nav-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
              </svg>
            </span>
            <span data-i18n="nav.dashboard">Dashboard</span>
          </a>
          <a href="/admin/orders" onclick="closeMobileSidebar()">
            <span class="nav-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>
              </svg>
            </span>
            <span data-i18n="nav.orders">Órdenes</span>
          </a>
          <a href="/admin/customers" onclick="closeMobileSidebar()">
            <span class="nav-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            </span>
            <span data-i18n="nav.customers">Clientes</span>
          </a>
        </nav>
        <div class="admin-sidebar-footer">
          <a href="/" onclick="closeMobileSidebar()">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px;">
              <polyline points="15 18 9 12 15 6"/>
            </svg>
            <span data-i18n="nav.back_to_site">Volver al sitio</span>
          </a>
          <a href="/api/admin/logout" class="logout-btn" style="cursor:pointer;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px;">
              <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
            <span data-i18n="nav.logout">Cerrar Sesión</span>
          </a>
        </div>
      </aside>

      <div class="admin-main">
        <div class="admin-topbar">
          <button class="mobile-sidebar-toggle" onclick="openMobileSidebar()" aria-label="Menú">☰</button>
          <h1>{title}</h1>
          <button class="lang-toggle" onclick="toggleLanguage()" id="lang-toggle">
            <span id="lang-label">{locale === 'en' ? 'Español' : 'English'}</span>
          </button>
        </div>
        <div class="admin-content">
          <slot />
        </div>
      </div>
    </div>

    <!-- i18n: set up window.__i18n synchronously so inline page scripts can use it -->
    <script is:inline define:vars={{ DICT, locale }}>
      window.__i18n = {
        DICT: DICT,
        getLocale: function() {
          var m = document.cookie.match(/tpt_lang=([^;]+)/);
          var v = m ? m[1] : null;
          return (v === 'en' || v === 'es') ? v : 'es';
        },
        t: function(key, loc) {
          var l = loc || this.getLocale();
          var entry = this.DICT[key];
          if (!entry) return key;
          return entry[l] || key;
        }
      };
      // Translate all data-i18n elements on DOMContentLoaded
      function translatePage() {
        var l = window.__i18n.getLocale();
        document.querySelectorAll('[data-i18n]').forEach(function(el) {
          var key = el.getAttribute('data-i18n');
          if (key) { el.textContent = window.__i18n.t(key, l); }
        });
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', translatePage);
      } else {
        translatePage();
      }

      // Layout helpers
      var LOCALE = locale;
      function toggleLanguage() {
        var newLang = LOCALE === 'es' ? 'en' : 'es';
        document.cookie = 'tpt_lang=' + newLang + '; path=/; max-age=' + (60 * 60 * 24 * 365) + '; SameSite=Lax';
        window.location.reload();
      }
      function openMobileSidebar() {
        document.getElementById('mobile-sidebar').classList.add('open');
        document.getElementById('sidebar-overlay').classList.add('open');
      }
      function closeMobileSidebar() {
        document.getElementById('mobile-sidebar').classList.remove('open');
        document.getElementById('sidebar-overlay').classList.remove('open');
      }
    </script>
  </body>
</html>
