---
export interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  /** Optional JSON-LD structured data objects to inject into the page */
  jsonLd?: object[] | object;
}

const { title, description, canonicalPath, jsonLd } = Astro.props;

const SITE_URL = 'https://trustparatodos.com';
const OG_IMAGE = `${SITE_URL}/og-image.png`;

// Determine canonical URL — use provided path or fall back to current URL path
const path = canonicalPath ?? Astro.url.pathname;
const canonicalURL = new URL(path, SITE_URL).href;

const ogType = path === '/' ? 'website' : 'article';

// Organization JSON-LD — present on all pages
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Trust Para Todos',
  url: SITE_URL,
  logo: `${SITE_URL}/assets/logo-shield.svg`,
  description: 'Plataforma de protección patrimonial con trusts para familias mexicanas en Estados Unidos.',
  sameAs: [
    'https://trustoffice.app',
    'https://wingpointtrust.com'
  ]
};

// Collect all JSON-LD objects
const allSchemas = [orgSchema];
if (jsonLd) {
  if (Array.isArray(jsonLd)) {
    allSchemas.push(...jsonLd);
  } else {
    allSchemas.push(jsonLd);
  }
}

import '../styles/fonts.css';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Trust Para Todos</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/assets/logo-shield.svg" />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph tags -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={OG_IMAGE} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Trust Para Todos" />
    <meta property="og:locale" content="es_ES" />

    <!-- Twitter Card tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={OG_IMAGE} />

    <!-- hreflang tags — Spanish is canonical, English available via cookie toggle -->
    <link rel="alternate" hreflang="es" href={canonicalURL} />
    <link rel="alternate" hreflang="en" href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL} />

    <!-- JSON-LD Structured Data -->
    {allSchemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <!-- Plausible Analytics -->
    <!-- TODO: Verify the Plausible instance URL — if using self-hosted, change src to your instance -->
    <script defer data-domain="trustparatodos.com" src="https://plausible.io/js/script.js"></script>
  </head>
  <body>
    <div class="noise-overlay"></div>

    <header class="header">
      <nav class="nav">
        <a href="/" class="logo">
          <span class="logo-icon">
            <img src="/assets/logo-shield.svg" alt="Trust Para Todos" width="28" height="28" />
          </span>
          <span class="logo-text">Trust Para Todos</span>
        </a>
        <div class="nav-links">
          <a href="/que-es">¿Qué es?</a>
          <a href="/como-funciona">Cómo funciona</a>
          <a href="/preguntas-frecuentes">FAQ</a>
          <a href="/evaluacion" class="btn btn-primary btn-sm">Tu evaluación</a>
          <div class="lang-toggle">
            <a href="#" data-lang="es" class="lang-link active">ES</a>
            <span class="lang-sep">|</span>
            <a href="#" data-lang="en" class="lang-link">EN</a>
          </div>
        </div>
        <button class="mobile-menu-btn" aria-label="Menú">☰</button>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-grid">
        <div>
          <div class="footer-brand">Trust Para Todos</div>
          <p>Protege a tu familia. Asegura tu legado.</p>
          <p class="footer-powered">Powered by <a href="https://trustoffice.app">TrustOffice</a></p>
        </div>
        <div>
          <h4>Enlaces</h4>
          <a href="/que-es">¿Qué es un trust?</a>
          <a href="/como-funciona">Cómo funciona</a>
          <a href="/preguntas-frecuentes">Preguntas frecuentes</a>
          <a href="/contacto">Contacto</a>
        </div>
        <div>
          <h4>Recursos</h4>
          <a href="/testimonios">Testimonios</a>
          <a href="/asociaciones">Asociaciones</a>
          <a href="/legal">Aviso legal</a>
        </div>
        <div>
          <h4>Contacto</h4>
          <!-- TODO: Replace with real WhatsApp number -->
          <a href="https://wa.me/18001234567" class="whatsapp-link">WhatsApp: ¡Escríbenos!</a>
          <a href="/contacto">Formulario de contacto</a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© 2026 Trust Para Todos. Todos los derechos reservados.</p>
        <p class="footer-disclaimer">Trust Para Todos proporciona documentos legales preparados por abogados. No somos un bufete de abogados. Este sitio no proporciona asesoramiento legal.</p>
      </div>
    </footer>

    <script>
      // Mobile menu toggle
      document.querySelector('.mobile-menu-btn')?.addEventListener('click', () => {
        document.querySelector('.nav-links')?.classList.toggle('open');
      });

      // Language toggle
      document.querySelectorAll('.lang-link').forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const lang = link.dataset.lang;
          if (!lang) return;
          document.cookie = `tpt_lang=${lang}; path=/; max-age=${365 * 24 * 60 * 60}`;
          window.location.reload();
        });
      });

      // Set active class based on current cookie
      const match = document.cookie.match(/tpt_lang=([^;]+)/);
      const currentLang = match?.[1] || 'es';
      document.querySelectorAll('.lang-link').forEach(link => {
        link.classList.toggle('active', link.dataset.lang === currentLang);
      });
    </script>
  </body>
</html>