---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getLocaleFromCookie, t } from '../../../lib/i18n';
const locale = getLocaleFromCookie(Astro.request.headers.get('cookie'));
---

<AdminLayout title={t('customer.title', locale)}>
  <style>
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      color: var(--text-muted);
      text-decoration: none;
      font-size: 0.85rem;
      margin-bottom: 20px;
    }
    .back-link:hover { color: var(--teal); }

    .detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 24px; }
    @media (max-width: 768px) { .detail-grid { grid-template-columns: 1fr; } }

    .section-card {
      background: var(--white);
      border: 1px solid var(--cream-dark);
      border-radius: var(--radius);
      padding: 24px;
    }
    .section-card h2 {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 1.1rem;
      color: var(--dark);
      margin-bottom: 16px;
      padding-bottom: 12px;
      border-bottom: 1px solid var(--cream-dark);
    }

    .info-row {
      display: flex;
      justify-content: space-between;
      padding: 8px 0;
      font-size: 0.85rem;
      border-bottom: 1px solid var(--cream-warm);
    }
    .info-row:last-child { border-bottom: none; }
    .info-row .label { color: var(--text-muted); font-weight: 500; }
    .info-row .value { color: var(--dark); font-weight: 600; }

    .order-table { width: 100%; border-collapse: collapse; }
    .order-table th {
      text-align: left;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-muted);
      padding: 10px 12px;
      border-bottom: 1px solid var(--cream-dark);
    }
    .order-table td {
      padding: 12px;
      font-size: 0.85rem;
      border-bottom: 1px solid var(--cream-dark);
    }
    .order-table tr:last-child td { border-bottom: none; }
    .order-table tr:hover td { background: var(--cream); cursor: pointer; }

    .status-badge {
      display: inline-block;
      font-size: 0.75rem;
      font-weight: 600;
      padding: 3px 10px;
      border-radius: 100px;
    }
    .status-badge.pending { background: #fef9e7; color: #92400e; }
    .status-badge.paid { background: #e6f7e6; color: #166534; }
    .status-badge.fulfilling { background: #e6f2f4; color: #04707e; }
    .status-badge.complete { background: #e6f7e6; color: #166534; }

    .plan-badge {
      display: inline-block;
      font-size: 0.75rem;
      font-weight: 600;
      padding: 3px 10px;
      border-radius: 100px;
      background: var(--teal-light);
      color: var(--teal);
    }
    .plan-badge.completo { background: var(--terracotta-light); color: var(--terracotta-dark); }

    .loading { text-align: center; padding: 60px; color: var(--text-muted); }
    .error-state { text-align: center; padding: 60px; color: #991b1b; }
  </style>

  <a href="/admin/customers" class="back-link" data-i18n="customer.back">{t('customer.back', locale)}</a>
  <div id="loading" class="loading" data-i18n="customers.loading">{t('customers.loading', locale)}</div>
  <div id="error-state" class="error-state" style="display:none;"></div>
  <div id="detail-content" style="display:none;">
    <div class="detail-grid">
      <div class="section-card">
        <h2 data-i18n="customer.info">{t('customer.info', locale)}</h2>
        <div id="customer-info"></div>
      </div>
      <div class="section-card">
        <h2>Cuestionario</h2>
        <div id="questionnaire-info">
          <p style="color:var(--text-muted); font-size:0.85rem;">Cargando datos del cuestionario...</p>
        </div>
      </div>
    </div>

    <div class="section-card">
      <h2 data-i18n="customer.order_history">{t('customer.order_history', locale)}</h2>
      <table class="order-table">
        <thead>
          <tr>
            <th>ID</th>
            <th data-i18n="orders.plan">{t('orders.plan', locale)}</th>
            <th data-i18n="orders.amount">{t('orders.amount', locale)}</th>
            <th data-i18n="orders.status">{t('orders.status', locale)}</th>
            <th data-i18n="order.documents">{t('order.documents', locale)}</th>
            <th data-i18n="orders.date">{t('orders.date', locale)}</th>
          </tr>
        </thead>
        <tbody id="orders-body"></tbody>
      </table>
    </div>
  </div>

  <script is:inline>
    const LOCALE = '{locale}';
    const i18n = window.__i18n || { t: function(k) { return k; }, getLocale: function() { return 'es'; } };
    const customerId = window.location.pathname.split('/').pop();

    async function loadCustomer() {
      try {
        var res = await fetch('/api/customers/' + customerId);
        if (!res.ok) { if (res.status === 401) { window.location.href = '/admin/login'; return; } throw new Error('Error'); }
        var data = await res.json();

        document.getElementById('loading').style.display = 'none';
        document.getElementById('detail-content').style.display = 'block';

        var customer = data.customer;
        var formatCurrency = function(cents) { return '$' + (cents / 100).toLocaleString('en-US', { minimumFractionDigits: 2 }); };
        var esc = function(s) { return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;'); };

        document.getElementById('customer-info').innerHTML = `
          <div class="info-row"><span class="label">${i18n.t('customers.name', LOCALE)}</span><span class="value">${esc(customer.name)}</span></div>
          <div class="info-row"><span class="label">${i18n.t('customers.email', LOCALE)}</span><span class="value">${esc(customer.email)}</span></div>
          <div class="info-row"><span class="label">${i18n.t('customers.phone', LOCALE)}</span><span class="value">${esc(customer.phone) || '—'}</span></div>
          <div class="info-row"><span class="label">${i18n.t('customers.registered', LOCALE)}</span><span class="value">${new Date(customer.created_at).toLocaleString(LOCALE === 'en' ? 'en-US' : 'es-MX')}</span></div>
        `;

        var qResponses = data.questionnaire_responses || [];
        if (qResponses.length > 0) {
          var latest = qResponses[0];
          var rawData = typeof latest.raw_data === 'string' ? JSON.parse(latest.raw_data) : latest.raw_data;
          var fields = [
            { label: 'Cónyuge', key: 'settlor_2_full_name' },
            { label: 'Ciudadanía', key: 'citizenship' },
            { label: 'Estado civil', key: 'marital_status' },
            { label: 'Hijos', key: 'number_of_children' },
            { label: 'Plan', key: 'plan_type' },
          ];
          document.getElementById('questionnaire-info').innerHTML = fields.map(function(f) {
            return '<div class="info-row"><span class="label">' + f.label + '</span><span class="value">' + (esc(rawData[f.key]) || '—') + '</span></div>';
          }).join('');
        } else {
          document.getElementById('questionnaire-info').innerHTML = '<p style="color:var(--text-muted); font-size:0.85rem;">Sin respuestas de cuestionario.</p>';
        }

        var orders = data.orders || [];
        var tbody = document.getElementById('orders-body');
        tbody.innerHTML = orders.map(function(o) {
          return `
          <tr onclick="window.location='/admin/orders/${esc(o.id)}'">
            <td style="font-family:monospace; font-size:0.8rem;">${esc(o.id.substring(0, 8))}...</td>
            <td><span class="plan-badge ${esc(o.plan_type)}">${i18n.t('plan.' + o.plan_type, LOCALE)}</span></td>
            <td>${formatCurrency(o.amount)}</td>
            <td><span class="status-badge ${esc(o.status)}">${i18n.t('status.' + o.status, LOCALE)}</span></td>
            <td>${o.document_count || 0} ${i18n.t('order.documents', LOCALE)}</td>
            <td>${new Date(o.created_at).toLocaleDateString(LOCALE === 'en' ? 'en-US' : 'es-MX')}</td>
          </tr>
        `;}).join('');
      } catch (e) {
        document.getElementById('loading').style.display = 'none';
        var errorEl = document.getElementById('error-state');
        errorEl.style.display = 'block';
        errorEl.textContent = 'Error: ' + e.message;
      }
    }

    loadCustomer();
  </script>
</AdminLayout>
