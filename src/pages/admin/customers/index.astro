---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getLocaleFromCookie, t } from '../../../lib/i18n';
const locale = getLocaleFromCookie(Astro.request.headers.get('cookie'));
---

<AdminLayout title={t('customers.title', locale)}>
  <style is:global>
    .toolbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
      gap: 16px;
      flex-wrap: wrap;
    }
    .search-box {
      display: flex;
      gap: 8px;
      flex: 1;
      max-width: 400px;
    }
    .search-box input {
      flex: 1;
      padding: 10px 14px;
      border: 1.5px solid var(--cream-dark);
      border-radius: var(--radius-sm);
      font-family: 'DM Sans', sans-serif;
      font-size: 0.9rem;
      outline: none;
    }
    .search-box input:focus { border-color: var(--teal); }

    .section-card {
      background: var(--white);
      border: 1px solid var(--cream-dark);
      border-radius: var(--radius);
      padding: 0;
      overflow: hidden;
    }
    .customer-table { width: 100%; border-collapse: collapse; }
    .customer-table th {
      text-align: left;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-muted);
      padding: 12px 14px;
      border-bottom: 2px solid var(--cream-dark);
      background: var(--white);
      position: sticky;
      top: 0;
      z-index: 1;
    }
    .customer-table td {
      padding: 14px 14px;
      font-size: 0.875rem;
      border-bottom: 1px solid var(--cream-dark);
    }
    .customer-table tbody tr:nth-child(even) td { background: var(--cream-warm); }
    .customer-table tbody tr:hover td { background: var(--cream); cursor: pointer; }
    .customer-cell { display: flex; align-items: center; gap: 10px; }
    .customer-avatar {
      width: 28px; height: 28px;
      border-radius: 50%;
      background: var(--teal-light);
      color: var(--teal);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.7rem;
      font-weight: 700;
      flex-shrink: 0;
    }
    .order-count { font-size: 0.8rem; font-weight: 600; padding: 2px 10px; border-radius: 100px; background: var(--teal-light); color: var(--teal); }

    .order-count {
      display: inline-block;
      font-size: 0.8rem;
      font-weight: 600;
      padding: 2px 10px;
      border-radius: 100px;
      background: var(--teal-light);
      color: var(--teal);
    }

    .pagination {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 12px;
      padding: 16px;
      font-size: 0.85rem;
      color: var(--text-muted);
    }
    .pagination button {
      padding: 6px 14px;
      border: 1px solid var(--cream-dark);
      border-radius: var(--radius-sm);
      background: var(--white);
      cursor: pointer;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.85rem;
    }
    .pagination button:hover { background: var(--cream); }
    .pagination button:disabled { opacity: 0.4; cursor: default; }

    .loading { text-align: center; padding: 60px; color: var(--text-muted); }
    .empty-state { text-align: center; padding: 60px; color: var(--text-muted); }
    .result-count { margin-left: auto; font-size: 0.85rem; color: var(--text-muted); white-space: nowrap; }
    .result-count strong { color: var(--dark); font-weight: 700; }
  </style>

  <div class="toolbar">
    <div class="search-box">
      <input type="text" id="search-input" data-i18n="customers.search" placeholder={t('customers.search', locale)} />
      <button class="btn btn-primary btn-sm" onclick="loadCustomers()" style="padding:10px 14px;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></button>
    </div>
  </div>

  <div id="loading" class="loading" data-i18n="customers.loading">{t('customers.loading', locale)}</div>
  <div id="empty-state" class="empty-state" style="display:none;" data-i18n="customers.no_results">{t('customers.no_results', locale)}</div>

  <div class="section-card" id="customers-table-container" style="display:none;">
    <table class="customer-table">
      <thead>
        <tr>
          <th data-i18n="customers.name">{t('customers.name', locale)}</th>
          <th data-i18n="customers.email">{t('customers.email', locale)}</th>
          <th data-i18n="customers.phone">{t('customers.phone', locale)}</th>
          <th data-i18n="customers.orders">{t('customers.orders', locale)}</th>
          <th data-i18n="customers.registered">{t('customers.registered', locale)}</th>
        </tr>
      </thead>
      <tbody id="customers-body"></tbody>
    </table>
    <div class="pagination" id="pagination"></div>
  </div>

  <script is:inline>
    const LOCALE = window.__i18n ? window.__i18n.getLocale() : '{locale}';
    const i18n = window.__i18n || { t: function(k) { return k; }, getLocale: function() { return 'es'; } };
    let currentPage = 1;

    async function loadCustomers() {
      var $search = document.getElementById('search-input');
      if (!$search) return;
      var search = $search.value;
      const params = new URLSearchParams({ page: String(currentPage), limit: '50' });
      if (search) params.set('search', search);

      document.getElementById('loading').style.display = 'block';
      document.getElementById('customers-table-container').style.display = 'none';
      document.getElementById('empty-state').style.display = 'none';

      try {
        const res = await fetch(`/api/customers?${params}`);
        if (!res.ok) { if (res.status === 401) { window.location.href = '/admin/login'; return; } throw new Error('Error'); }
        const data = await res.json();

        document.getElementById('loading').style.display = 'none';

        if (data.customers.length === 0) {
          document.getElementById('empty-state').style.display = 'block';
          return;
        }

        document.getElementById('customers-table-container').style.display = 'block';

        const tbody = document.getElementById('customers-body');
        var esc = function(s) { return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;'); };
        tbody.innerHTML = data.customers.map(function(c) {
          return `
          <tr onclick="window.location='/admin/customers/${esc(c.id)}'">
            <td class="customer-cell"><span class="customer-avatar">${esc((c.name || "").split(" ").map(function(w) { return w.charAt(0); }).join("").substring(0, 2).toUpperCase())}</span><strong>${esc(c.name)}</strong></td>
            <td>${esc(c.email)}</td>
            <td>${esc(c.phone) || '—'}</td>
            <td><span class="order-count">${c.order_count === 1 ? "1 " + (LOCALE === "en" ? "order" : "orden") : c.order_count + " " + (LOCALE === "en" ? "orders" : "ordenes")}</span></td>
            <td>${new Date(c.created_at).toLocaleDateString(LOCALE === 'en' ? 'en-US' : 'es-MX')}</td>
          </tr>
        `;}).join('');

        var totalPages = Math.ceil(data.total / data.limit);
        var pagination = document.getElementById('pagination');
        pagination.innerHTML = `
          <button onclick="changePage(${currentPage - 1})" ${currentPage <= 1 ? 'disabled' : ''}>← ${i18n.t('orders.all', LOCALE) === 'All' ? 'Previous' : 'Anterior'}</button>
          <span>${i18n.t('orders.all', LOCALE) === 'All' ? 'Page' : 'Página'} ${data.page} ${i18n.t('orders.all', LOCALE) === 'All' ? 'of' : 'de'} ${totalPages || 1} (${data.total} ${i18n.t('orders.all', LOCALE) === 'All' ? 'total' : 'total'})</span>
          <button onclick="changePage(${currentPage + 1})" ${currentPage >= totalPages ? 'disabled' : ''}>${i18n.t('orders.all', LOCALE) === 'All' ? 'Next' : 'Siguiente'} →</button>
        `;
      } catch (e) {
        document.getElementById('loading').style.display = 'none';
        document.getElementById('empty-state').style.display = 'block';
        document.getElementById('empty-state').textContent = 'Error: ' + e.message;
      }
    }

    function changePage(page) {
      currentPage = page;
      loadCustomers();
    }

    loadCustomers();
  </script>
</AdminLayout>
