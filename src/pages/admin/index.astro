---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getLocaleFromCookie, t } from '../../lib/i18n';
const locale = getLocaleFromCookie(Astro.request.headers.get('cookie'));
---

<AdminLayout title={t('dashboard.title', locale)}>
  <style>
    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 32px; }
    .stat-card {
      background: var(--white);
      border: 1px solid var(--cream-dark);
      border-radius: var(--radius);
      padding: 24px;
    }
    .stat-card .stat-label { font-size: 0.8rem; color: var(--text-muted); font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; }
    .stat-card .stat-value { font-family: 'Playfair Display', Georgia, serif; font-size: 2rem; font-weight: 700; color: var(--dark); }
    .stat-card .stat-sub { font-size: 0.8rem; color: var(--text-muted); margin-top: 4px; }
    .stat-card.teal .stat-value { color: var(--teal); }
    .stat-card.terracotta .stat-value { color: var(--terracotta); }

    .section-card {
      background: var(--white);
      border: 1px solid var(--cream-dark);
      border-radius: var(--radius);
      padding: 24px;
      margin-bottom: 24px;
    }
    .section-card h2 {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 1.1rem;
      color: var(--dark);
      margin-bottom: 16px;
    }

    .order-table { width: 100%; border-collapse: collapse; }
    .order-table th {
      text-align: left;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-muted);
      padding: 10px 12px;
      border-bottom: 1px solid var(--cream-dark);
    }
    .order-table td {
      padding: 12px;
      font-size: 0.85rem;
      border-bottom: 1px solid var(--cream-dark);
    }
    .order-table tr:last-child td { border-bottom: none; }
    .order-table tr:hover td { background: var(--cream); }

    .status-badge {
      display: inline-block;
      font-size: 0.75rem;
      font-weight: 600;
      padding: 3px 10px;
      border-radius: 100px;
    }
    .status-badge.pending { background: #fef9e7; color: #92400e; }
    .status-badge.paid { background: #e6f7e6; color: #166534; }
    .status-badge.fulfilling { background: #e6f2f4; color: #04707e; }
    .status-badge.complete { background: #e6f7e6; color: #166534; }

    .plan-badge {
      display: inline-block;
      font-size: 0.75rem;
      font-weight: 600;
      padding: 3px 10px;
      border-radius: 100px;
      background: var(--teal-light);
      color: var(--teal);
    }
    .plan-badge.completo { background: var(--terracotta-light); color: var(--terracotta-dark); }

    .loading { text-align: center; padding: 60px; color: var(--text-muted); }
    .error-state { text-align: center; padding: 60px; color: #991b1b; }
  </style>

  <div id="dashboard-loading" class="loading" data-i18n="dashboard.loading">{t('dashboard.loading', locale)}</div>
  <div id="dashboard-error" class="error-state" style="display:none;"></div>
  <div id="dashboard-content" style="display:none;">
    <div class="stats-grid" id="stats-grid"></div>
    <div class="section-card">
      <h2 data-i18n="dashboard.recent_orders">{t('dashboard.recent_orders', locale)}</h2>
      <table class="order-table" id="recent-orders">
        <thead>
          <tr>
            <th data-i18n="orders.customer">{t('orders.customer', locale)}</th>
            <th data-i18n="orders.email">{t('orders.email', locale)}</th>
            <th data-i18n="orders.plan">{t('orders.plan', locale)}</th>
            <th data-i18n="orders.amount">{t('orders.amount', locale)}</th>
            <th data-i18n="orders.status">{t('orders.status', locale)}</th>
            <th data-i18n="orders.date">{t('orders.date', locale)}</th>
          </tr>
        </thead>
        <tbody id="recent-orders-body"></tbody>
      </table>
    </div>
  </div>

  <script>
    const LOCALE = '{locale}';
    const i18n = (window as any).__i18n || { t: (k: string) => k, getLocale: () => 'es' };

    async function loadDashboard() {
      try {
        const res = await fetch('/api/admin/stats');
        if (!res.ok) {
          if (res.status === 401) { window.location.href = '/admin/login'; return; }
          throw new Error(i18n.t('dashboard.error', LOCALE));
        }
        const data = await res.json();

        document.getElementById('dashboard-loading').style.display = 'none';
        document.getElementById('dashboard-content').style.display = 'block';

        const statsGrid = document.getElementById('stats-grid');
        const formatCurrency = (cents: number) => `$${(cents / 100).toLocaleString('en-US', { minimumFractionDigits: 2 })}`;
        
        statsGrid.innerHTML = `
          <div class="stat-card teal">
            <div class="stat-label">${i18n.t('dashboard.total_orders', LOCALE)}</div>
            <div class="stat-value">${data.total_orders}</div>
          </div>
          <div class="stat-card">
            <div class="stat-label">${i18n.t('dashboard.orders_today', LOCALE)}</div>
            <div class="stat-value">${data.orders_today}</div>
          </div>
          <div class="stat-card terracotta">
            <div class="stat-label">${i18n.t('dashboard.pending', LOCALE)}</div>
            <div class="stat-value">${data.pending_fulfillment}</div>
          </div>
          <div class="stat-card teal">
            <div class="stat-label">${i18n.t('dashboard.revenue', LOCALE)}</div>
            <div class="stat-value">$${Number(data.revenue).toLocaleString('en-US', { minimumFractionDigits: 2 })}</div>
          </div>
        `;

        const tbody = document.getElementById('recent-orders-body');
        const esc = (s: any) => String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\"/g,'&quot;').replace(/'/g,'&#39;');

        tbody.innerHTML = data.recent_orders.map((o: any) => `
          <tr onclick="window.location='/admin/orders/${esc(o.id)}'" style="cursor:pointer;">
            <td><strong>${esc(o.customer_name)}</strong></td>
            <td>${esc(o.customer_email)}</td>
            <td><span class="plan-badge ${esc(o.plan_type)}">${i18n.t('plan.' + o.plan_type, LOCALE)}</span></td>
            <td>${formatCurrency(o.amount)}</td>
            <td><span class="status-badge ${esc(o.status)}">${i18n.t('status.' + o.status, LOCALE)}</span></td>
            <td>${new Date(o.created_at).toLocaleDateString(LOCALE === 'en' ? 'en-US' : 'es-MX')}</td>
          </tr>
        `).join('');
      } catch (e: any) {
        document.getElementById('dashboard-loading').style.display = 'none';
        const errorEl = document.getElementById('dashboard-error');
        errorEl.style.display = 'block';
        errorEl.textContent = i18n.t('dashboard.error', LOCALE) + ': ' + e.message;
      }
    }

    loadDashboard();
  </script>
</AdminLayout>
