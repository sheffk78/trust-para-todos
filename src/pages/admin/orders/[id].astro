---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getLocaleFromCookie, t } from '../../../lib/i18n';
const locale = getLocaleFromCookie(Astro.request.headers.get('cookie'));
---

<AdminLayout title={t('order.title', locale)}>
  <style is:global>
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      color: var(--text-muted);
      text-decoration: none;
      font-size: 0.85rem;
      margin-bottom: 20px;
    }
    .back-link:hover { color: var(--teal); }
    .customer-link { color: var(--teal); text-decoration: none; font-weight: 600; }
    .customer-link:hover { text-decoration: underline; }
    .contact-link { color: var(--text-body); text-decoration: none; }
    .contact-link:hover { color: var(--teal); text-decoration: underline; }

    .detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 24px; }
    @media (max-width: 768px) { .detail-grid { grid-template-columns: 1fr; } }

    .section-card {
      background: var(--white);
      border: 1px solid var(--cream-dark);
      border-radius: var(--radius);
      padding: 24px;
    }
    .section-card h2 {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 1.1rem;
      color: var(--dark);
      margin-bottom: 16px;
      padding-bottom: 12px;
      border-bottom: 1px solid var(--cream-dark);
    }

    .info-row {
      display: flex;
      justify-content: space-between;
      padding: 8px 0;
      font-size: 0.85rem;
      border-bottom: 1px solid var(--cream-warm);
    }
    .info-row:last-child { border-bottom: none; }
    .info-row .label { color: var(--text-muted); font-weight: 500; }
    .info-row .value { color: var(--dark); font-weight: 600; }

    .status-badge {
      display: inline-block;
      font-size: 0.75rem;
      font-weight: 600;
      padding: 3px 10px;
      border-radius: 100px;
    }
    .status-badge.pending { background: #fef9e7; color: #92400e; }
    .status-badge.paid { background: #e6f7e6; color: #166534; }
    .status-badge.fulfilling { background: #e6f2f4; color: #04707e; }
    .status-badge.complete { background: #e6f7e6; color: #166534; }
    .status-badge.in_progress { background: #e6f2f4; color: #04707e; }
    .status-badge.completed { background: #e6f7e6; color: #166534; }
    .status-badge.skipped { background: #f4f2eb; color: #7a7a88; }
    .status-badge.failed { background: #fef2f2; color: #991b1b; }
    .status-badge.generating { background: #e6f2f4; color: #04707e; }
    .status-badge.ready { background: #e6f7e6; color: #166534; }
    .status-badge.error { background: #fef2f2; color: #991b1b; }

    .fulfillment-progress {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 24px;
      padding: 16px 20px;
      background: var(--cream-warm);
      border-radius: var(--radius-sm);
    }
    .fulfillment-progress-bar {
      flex: 1;
      height: 8px;
      background: var(--cream-dark);
      border-radius: 4px;
      overflow: hidden;
    }
    .fulfillment-progress-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--teal), var(--terracotta));
      border-radius: 4px;
      transition: width 0.6s ease;
    }
    .fulfillment-progress-text {
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--dark);
      white-space: nowrap;
      flex-shrink: 0;
    }
    .fulfillment-tracker {
      display: flex;
      justify-content: space-between;
      gap: 0;
      position: relative;
      padding: 32px 24px 16px;
    }
    .fulfillment-tracker::before {
      content: '';
      position: absolute;
      top: 48px;
      left: 48px;
      right: 48px;
      height: 2px;
      background: var(--tracker-line, var(--cream-dark));
      z-index: 0;
    }
    .fulfillment-step {
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      flex: 1;
      min-width: 0;
      z-index: 1;
    }
    .fulfillment-step .step-dot {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.75rem;
      margin-bottom: 8px;
      flex-shrink: 0;
    }
    .fulfillment-step .step-name { font-weight: 600; font-size: 0.75rem; color: var(--dark); line-height: 1.2; max-width: 100px; }
    .fulfillment-step .step-meta { font-size: 0.7rem; color: var(--text-muted); margin-top: 4px; max-width: 120px; }

    .doc-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 0;
      border-bottom: 1px solid var(--cream-warm);
    }
    .doc-item:last-child { border-bottom: none; }
    .doc-info { display: flex; align-items: center; gap: 10px; }
    .doc-icon {
      width: 36px; height: 36px;
      background: var(--teal-light);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .doc-name { font-weight: 600; font-size: 0.85rem; color: var(--dark); }
    .doc-meta { font-size: 0.8rem; color: var(--text-muted); }

    .btn-download {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 14px;
      background: var(--teal);
      color: white;
      border: none;
      border-radius: 100px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.75rem;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      transition: all 0.2s;
    }
    .btn-download:hover { background: var(--teal-dark); transform: translateY(-1px); }

    .doc-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
    @media (max-width: 768px) { .doc-grid { grid-template-columns: 1fr; } }
    .doc-section { margin-bottom: 20px; }
    .doc-section-title {
      grid-column: 1 / -1;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-muted);
      padding-bottom: 8px;
      border-bottom: 1px solid var(--cream-dark);
      margin-bottom: 8px;
    }
    .action-bar {
      display: flex;
      gap: 12px;
      margin-top: 24px;
    }

    .order-summary-header {
      background: var(--white);
      border: 1px solid var(--cream-dark);
      border-radius: var(--radius);
      padding: 20px 24px;
      margin-bottom: 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
    }
    .order-summary-header .btn-sm {
      padding: 6px 14px !important;
      font-size: 0.75rem !important;
    }
    .loading { text-align: center; padding: 60px; color: var(--text-muted); }
    .error-state { text-align: center; padding: 60px; color: #991b1b; }
  </style>

  <a href="/admin/orders" class="back-link" data-i18n="order.back">{t('order.back', locale)}</a>
  <div id="loading" class="loading" data-i18n="orders.loading">{t('orders.loading', locale)}</div>
  <div id="error-state" class="error-state" style="display:none;"></div>
  <div id="detail-content" style="display:none;">
    <div class="order-summary-header" id="order-summary-header" style="display:none;"></div>
    <div class="detail-grid">
      <div class="section-card">
        <h2 data-i18n="order.title">{t('order.title', locale)}</h2>
        <div id="order-info"></div>
      </div>
      <div class="section-card">
        <h2 data-i18n="order.customer_info">{t('order.customer_info', locale)}</h2>
        <div id="customer-info"></div>
      </div>
    </div>

    <div class="section-card" style="margin-bottom:24px;">
      <h2 data-i18n="order.fulfillment">{t('order.fulfillment', locale)}</h2>
      <div class="fulfillment-progress" id="fulfillment-progress" style="display:none;">
        <div class="fulfillment-progress-bar">
          <div class="fulfillment-progress-fill" id="fulfillment-progress-fill" style="width:0%;"></div>
        </div>
        <span class="fulfillment-progress-text" id="fulfillment-progress-text"></span>
      </div>
      <div class="fulfillment-tracker" id="fulfillment-steps"></div>
    </div>

    <div class="section-card" style="margin-bottom:24px;">
      <h2 data-i18n="order.documents">{t('order.documents', locale)}</h2>
      <div id="documents-list">
        <p style="color:var(--text-muted); font-size:0.85rem;" data-i18n="order.documents">{t('order.documents', locale)}</p>
      </div>
    </div>


  </div>

  <script is:inline>
    const LOCALE = window.__i18n ? window.__i18n.getLocale() : '{locale}';
    const i18n = window.__i18n || { t: function(k) { return k; }, getLocale: function() { return 'es'; } };
    const orderId = window.location.pathname.split('/').pop();

    // SVG icons for fulfillment steps (brand-style line art, teal stroke)
    var stepSvgIcons = {
      payment_confirmed: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px;"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>',
      document_generation: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px;"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>',
      ein_filing: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px;"><path d="M4 4h16v16H4z"/><line x1="8" y1="8" x2="16" y2="8"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="8" y1="16" x2="12" y2="16"/></svg>',
      notary_scheduling: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px;"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>',
      welcome_email: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px;"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>',
      final_delivery: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px;"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>'
    };

    async function loadOrder() {
      try {
        var res = await fetch('/api/orders/' + orderId);
        if (!res.ok) { if (res.status === 401) { window.location.href = '/admin/login'; return; } throw new Error('Error'); }
        var data = await res.json();

        document.getElementById('loading').style.display = 'none';
        document.getElementById('detail-content').style.display = 'block';

        var order = data.order;
        var formatCurrency = function(cents) { return '$' + (cents / 100).toLocaleString('en-US', { minimumFractionDigits: 2 }); };
        var esc = function(s) { return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;'); };

        document.getElementById('order-info').innerHTML = `
          <div class="info-row"><span class="label">ID</span><span class="value">${order.id.substring(0, 8)}...</span></div>
          <div class="info-row"><span class="label">${i18n.t('orders.plan', LOCALE)}</span><span class="value">${i18n.t('order.plan_' + order.plan_type, LOCALE)}</span></div>
          <div class="info-row"><span class="label">${i18n.t('orders.amount', LOCALE)}</span><span class="value">${formatCurrency(order.amount)}</span></div>
          <div class="info-row"><span class="label">${i18n.t('orders.status', LOCALE)}</span><span class="value"><span class="status-badge ${order.status}">${i18n.t('status.' + order.status, LOCALE)}</span></span></div>
          <div class="info-row"><span class="label">${i18n.t('order.created', LOCALE)}</span><span class="value">${new Date(order.created_at).toLocaleString(LOCALE === 'en' ? 'en-US' : 'es-MX')}</span></div>
          <div class="info-row"><span class="label">${i18n.t('order.updated', LOCALE)}</span><span class="value">${new Date(order.updated_at).toLocaleString(LOCALE === 'en' ? 'en-US' : 'es-MX')}</span></div>
        `;

        document.getElementById('customer-info').innerHTML = [
          '<div class="info-row"><span class="label">' + i18n.t('customers.name', LOCALE) + '</span><span class="value"><a href="/admin/customers/' + esc(order.customer_id) + '" class="customer-link">' + esc(order.customer_name) + '</a></span></div>',
          '<div class="info-row"><span class="label">' + i18n.t('customers.email', LOCALE) + '</span><span class="value"><a href="mailto:' + esc(order.customer_email) + '" class="contact-link">' + esc(order.customer_email) + '</a></span></div>',
          '<div class="info-row"><span class="label">' + i18n.t('customers.phone', LOCALE) + '</span><span class="value">' + (order.customer_phone ? '<a href="tel:' + esc(order.customer_phone) + '" class="contact-link">' + esc(order.customer_phone) + '</a>' : '—') + '</span></div>'
        ].join('');

        // Order summary header
        var sum = document.getElementById('order-summary-header');
        if (sum) {
          sum.style.display = 'flex';
          sum.innerHTML = '<div><h3 style="font-family:DM Sans,sans-serif;font-size:1.05rem;margin:0;color:var(--dark);">' + esc(order.customer_name) + '</h3><div style="display:flex;align-items:center;gap:10px;margin-top:6px;"><span class="plan-badge ' + esc(order.plan_type) + '">' + i18n.t('plan.' + order.plan_type, LOCALE) + '</span><span class="status-badge ' + esc(order.status) + '">' + i18n.t('status.' + order.status, LOCALE) + '</span><span style="font-size:1rem;font-weight:700;color:var(--dark);">' + formatCurrency(order.amount) + '</span></div></div><div><button class="btn btn-primary btn-sm" onclick="generateDocs()">' + i18n.t('order.generate_docs', LOCALE) + '</button></div>';
        }

        var steps = data.fulfillment_steps || [];

        var tracker = document.getElementById('fulfillment-steps');
        var progressEl = document.getElementById('fulfillment-progress');
        var progressFill = document.getElementById('fulfillment-progress-fill');
        var progressText = document.getElementById('fulfillment-progress-text');
        if (steps.length > 0 && progressEl) {
          var completedCount = steps.filter(function(s) { return s.status === 'completed' || s.status === 'skipped'; }).length;
          var pct = Math.round(completedCount / steps.length * 100);
          progressEl.style.display = 'flex';
          progressFill.style.width = pct + '%';
          progressText.textContent = completedCount + ' de ' + steps.length + ' (' + pct + '%)';
          // Dynamic line
          var stepPct = 100 / steps.length;
          var tealPct = completedCount * stepPct;
          tracker.style.setProperty('--tracker-line', 'linear-gradient(to right, var(--teal) 0%, var(--teal) ' + tealPct + '%, var(--cream-dark) ' + tealPct + '%, var(--cream-dark) 100%)');
        }
        tracker.innerHTML = steps.map(function(s) {
          var dotBg = '#e8e4d8';
          var dotContent = stepSvgIcons[s.step_name] || '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px;"><circle cx="12" cy="12" r="10"/></svg>';
          if (s.status === 'completed') { dotBg = 'var(--teal)'; dotContent = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px;"><polyline points="20 6 9 17 4 12"/></svg>'; }
          else if (s.status === 'in_progress') { dotBg = 'var(--terracotta)'; }
          else if (s.status === 'failed') { dotBg = '#991b1b'; dotContent = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px;"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>'; }
          else if (s.status === 'skipped') { dotBg = '#7a7a88'; dotContent = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px;"><line x1="5" y1="12" x2="19" y2="12"/></svg>'; }

          return `
            <div class="fulfillment-step">
              <div class="step-dot" style="background:${dotBg}; color:white; display:flex; align-items:center; justify-content:center;">${dotContent}</div>
              <div class="step-name">${esc(i18n.t('step.' + s.step_name, LOCALE))}</div>
              <div class="step-meta">
                <span class="status-badge ${esc(s.status)}">${esc(i18n.t('step.' + s.status, LOCALE))}</span>
                ${s.completed_at ? ' &mdash; ' + new Date(s.completed_at).toLocaleString(LOCALE === 'en' ? 'en-US' : 'es-MX') : ''}
                ${s.notes ? ' &mdash; ' + esc(s.notes) : ''}
              </div>
            </div>
          `;
        }).join('');

        var docs = data.documents || [];
        var docsList = document.getElementById('documents-list');
        if (docs.length === 0) {
          docsList.innerHTML = '<p style="color:var(--text-muted); font-size:0.85rem;">' + i18n.t('order.documents', LOCALE) + '</p>';
        } else {
          // Group documents into legal and support categories
          var legalDocs = docs.filter(function(d) { return ['trust', 'ilit'].indexOf(d.document_type) >= 0; });
          var supportDocs = docs.filter(function(d) { return ['ein', 'guide'].indexOf(d.document_type) >= 0; });
          var otherDocs = docs.filter(function(d) { return ['trust', 'ilit', 'ein', 'guide'].indexOf(d.document_type) < 0; });

          var docSvgIcon = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:18px;height:18px;stroke:#04707e;"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>';

          var downloadSvgIcon = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>';

          function renderDocItem(d) {
            var isReady = d.status === 'ready';
            var statusLabel = isReady ? i18n.t('doc.ready', LOCALE) : (d.status === 'pending' ? i18n.t('doc.pending', LOCALE) : i18n.t('doc.error', LOCALE));
            var statusClass = isReady ? 'ready' : (d.status === 'pending' ? 'pending' : 'error');
            return '<div class="doc-item">' +
              '<div class="doc-info">' +
                '<div class="doc-icon">' + docSvgIcon + '</div>' +
                '<div>' +
                  '<div class="doc-name">' + esc(i18n.t('doc.' + d.document_type, LOCALE)) + '</div>' +
                  '<div class="doc-meta">' + new Date(d.created_at).toLocaleString(LOCALE === 'en' ? 'en-US' : 'es-MX') + '</div>' +
                '</div>' +
              '</div>' +
              '<div style="display:flex; align-items:center; gap:10px;">' +
                '<span class="status-badge ' + esc(statusClass) + '">' + esc(statusLabel) + '</span>' +
                (isReady ? '<a href="/api/orders/' + orderId + '/documents/' + d.id + '/download" class="btn-download">' + downloadSvgIcon + ' ' + i18n.t('order.download', LOCALE) + '</a>' : '') +
              '</div>' +
            '</div>';
          }

          var html = '<div class="doc-grid">';
          if (legalDocs.length > 0) {
            html += '<div class="doc-section-title">Legal Documents</div>';
            html += legalDocs.map(renderDocItem).join('');
          }
          if (supportDocs.length > 0) {
            html += '<div class="doc-section-title">Supporting Documents</div>';
            html += supportDocs.map(renderDocItem).join('');
          }
          if (otherDocs.length > 0) {
            html += '<div class="doc-section-title">Otros</div>';
            html += otherDocs.map(renderDocItem).join('');
          }
          html += '</div>';
          docsList.innerHTML = html;
        }
      } catch (e) {
        document.getElementById('loading').style.display = 'none';
        var errorEl = document.getElementById('error-state');
        errorEl.style.display = 'block';
        errorEl.textContent = 'Error: ' + e.message;
      }
    }

    async function generateDocs() {
      if (!confirm(i18n.t('order.generate_docs', LOCALE) + '?')) return;
      try {
        var res = await fetch('/api/orders/' + orderId + '/generate-docs', { method: 'POST' });
        if (!res.ok) throw new Error('Error');
        var data = await res.json();
        alert(i18n.t('order.documents', LOCALE) + ': ' + (data.documents ? data.documents.length : 0));
        loadOrder();
      } catch (e) {
        alert('Error: ' + e.message);
      }
    }

    loadOrder();
  </script>
</AdminLayout>
