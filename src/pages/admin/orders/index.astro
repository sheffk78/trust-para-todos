---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getLocaleFromCookie, t } from '../../../lib/i18n';
const locale = getLocaleFromCookie(Astro.request.headers.get('cookie'));
---

<AdminLayout title={t('orders.title', locale)}>
  <style>
    .toolbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
      gap: 16px;
      flex-wrap: wrap;
    }
    .search-box {
      display: flex;
      gap: 8px;
      flex: 1;
      max-width: 400px;
    }
    .search-box input {
      flex: 1;
      padding: 10px 14px;
      border: 1.5px solid var(--cream-dark);
      border-radius: var(--radius-sm);
      font-family: 'DM Sans', sans-serif;
      font-size: 0.9rem;
      outline: none;
    }
    .search-box input:focus { border-color: var(--teal); }
    .filter-group { display: flex; gap: 8px; }
    .filter-group select {
      padding: 10px 14px;
      border: 1.5px solid var(--cream-dark);
      border-radius: var(--radius-sm);
      font-family: 'DM Sans', sans-serif;
      font-size: 0.85rem;
      background: var(--white);
      outline: none;
    }

    .section-card {
      background: var(--white);
      border: 1px solid var(--cream-dark);
      border-radius: var(--radius);
      padding: 0;
      overflow: hidden;
    }
    .order-table { width: 100%; border-collapse: collapse; }
    .order-table th {
      text-align: left;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-muted);
      padding: 14px 16px;
      border-bottom: 1px solid var(--cream-dark);
      background: var(--cream);
    }
    .order-table td {
      padding: 14px 16px;
      font-size: 0.85rem;
      border-bottom: 1px solid var(--cream-dark);
    }
    .order-table tr:last-child td { border-bottom: none; }
    .order-table tr:hover td { background: var(--cream); cursor: pointer; }

    .status-badge {
      display: inline-block;
      font-size: 0.75rem;
      font-weight: 600;
      padding: 3px 10px;
      border-radius: 100px;
    }
    .status-badge.pending { background: #fef9e7; color: #92400e; }
    .status-badge.paid { background: #e6f7e6; color: #166534; }
    .status-badge.fulfilling { background: #e6f2f4; color: #04707e; }
    .status-badge.complete { background: #e6f7e6; color: #166534; }

    .plan-badge {
      display: inline-block;
      font-size: 0.75rem;
      font-weight: 600;
      padding: 3px 10px;
      border-radius: 100px;
      background: var(--teal-light);
      color: var(--teal);
    }
    .plan-badge.completo { background: var(--terracotta-light); color: var(--terracotta-dark); }

    .pagination {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 12px;
      padding: 16px;
      font-size: 0.85rem;
      color: var(--text-muted);
    }
    .pagination button {
      padding: 6px 14px;
      border: 1px solid var(--cream-dark);
      border-radius: var(--radius-sm);
      background: var(--white);
      cursor: pointer;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.85rem;
    }
    .pagination button:hover { background: var(--cream); }
    .pagination button:disabled { opacity: 0.4; cursor: default; }

    .loading { text-align: center; padding: 60px; color: var(--text-muted); }
    .empty-state { text-align: center; padding: 60px; color: var(--text-muted); }
  </style>

  <div class="toolbar">
    <div class="search-box">
      <input type="text" id="search-input" data-i18n="orders.search" placeholder={t('orders.search', locale)} />
      <button class="btn btn-primary btn-sm" onclick="loadOrders()" data-i18n="orders.search">{t('orders.search', locale)}</button>
    </div>
    <div class="filter-group">
      <select id="status-filter" onchange="loadOrders()">
        <option value="" data-i18n="orders.all">{t('orders.all', locale)}</option>
        <option value="pending" data-i18n="status.pending">{t('status.pending', locale)}</option>
        <option value="paid" data-i18n="status.paid">{t('status.paid', locale)}</option>
        <option value="fulfilling" data-i18n="status.fulfilling">{t('status.fulfilling', locale)}</option>
        <option value="complete" data-i18n="status.complete">{t('status.complete', locale)}</option>
      </select>
      <select id="plan-filter" onchange="loadOrders()">
        <option value="" data-i18n="orders.all">{t('orders.all', locale)}</option>
        <option value="base" data-i18n="plan.base">{t('plan.base', locale)}</option>
        <option value="completo" data-i18n="plan.completo">{t('plan.completo', locale)}</option>
      </select>
    </div>
  </div>

  <div id="loading" class="loading" data-i18n="orders.loading">{t('orders.loading', locale)}</div>
  <div id="empty-state" class="empty-state" style="display:none;" data-i18n="orders.no_results">{t('orders.no_results', locale)}</div>

  <div class="section-card" id="orders-table-container" style="display:none;">
    <table class="order-table">
      <thead>
        <tr>
          <th data-i18n="orders.customer">{t('orders.customer', locale)}</th>
          <th data-i18n="orders.email">{t('orders.email', locale)}</th>
          <th data-i18n="orders.plan">{t('orders.plan', locale)}</th>
          <th data-i18n="orders.amount">{t('orders.amount', locale)}</th>
          <th data-i18n="orders.status">{t('orders.status', locale)}</th>
          <th data-i18n="orders.date">{t('orders.date', locale)}</th>
        </tr>
      </thead>
      <tbody id="orders-body"></tbody>
    </table>
    <div class="pagination" id="pagination"></div>
  </div>

  <script is:inline>
    const LOCALE = '{locale}';
    const i18n = window.__i18n || { t: function(k) { return k; }, getLocale: function() { return 'es'; } };
    let currentPage = 1;

    async function loadOrders() {
      const search = (document.getElementById('search-input') as HTMLInputElement).value;
      const status = (document.getElementById('status-filter') as HTMLSelectElement).value;
      const plan = (document.getElementById('plan-filter') as HTMLSelectElement).value;

      const params = new URLSearchParams({ page: String(currentPage), limit: '50' });
      if (search) params.set('search', search);
      if (status) params.set('status', status);
      if (plan) params.set('plan', plan);

      document.getElementById('loading').style.display = 'block';
      document.getElementById('orders-table-container').style.display = 'none';
      document.getElementById('empty-state').style.display = 'none';

      try {
        const res = await fetch(`/api/orders?${params}`);
        if (!res.ok) { if (res.status === 401) { window.location.href = '/admin/login'; return; } throw new Error('Error'); }
        const data = await res.json();

        document.getElementById('loading').style.display = 'none';

        if (data.orders.length === 0) {
          document.getElementById('empty-state').style.display = 'block';
          return;
        }

        document.getElementById('orders-table-container').style.display = 'block';

        const tbody = document.getElementById('orders-body');
        var formatCurrency = function(cents) { return '$' + (cents / 100).toLocaleString('en-US', { minimumFractionDigits: 2 }); };
        var esc = function(s) { return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;'); };

        tbody.innerHTML = data.orders.map(function(o) {
          return `
          <tr onclick="window.location='/admin/orders/${esc(o.id)}'">
            <td><strong>${esc(o.customer_name)}</strong></td>
            <td>${esc(o.customer_email)}</td>
            <td><span class="plan-badge ${esc(o.plan_type)}">${i18n.t('plan.' + o.plan_type, LOCALE)}</span></td>
            <td>${formatCurrency(o.amount)}</td>
            <td><span class="status-badge ${esc(o.status)}">${i18n.t('status.' + o.status, LOCALE)}</span></td>
            <td>${new Date(o.created_at).toLocaleDateString(LOCALE === 'en' ? 'en-US' : 'es-MX')}</td>
          </tr>
        `;}).join('');

        var totalPages = Math.ceil(data.total / data.limit);
        var pagination = document.getElementById('pagination');
        pagination.innerHTML = `
          <button onclick="changePage(${currentPage - 1})" ${currentPage <= 1 ? 'disabled' : ''}>← ${i18n.t('orders.all', LOCALE) === 'All' ? 'Previous' : 'Anterior'}</button>
          <span>${i18n.t('orders.all', LOCALE) === 'All' ? 'Page' : 'Página'} ${data.page} ${i18n.t('orders.all', LOCALE) === 'All' ? 'of' : 'de'} ${totalPages || 1} (${data.total} ${i18n.t('orders.all', LOCALE) === 'All' ? 'total' : 'total'})</span>
          <button onclick="changePage(${currentPage + 1})" ${currentPage >= totalPages ? 'disabled' : ''}>${i18n.t('orders.all', LOCALE) === 'All' ? 'Next' : 'Siguiente'} →</button>
        `;
      } catch (e) {
        document.getElementById('loading').style.display = 'none';
        document.getElementById('empty-state').style.display = 'block';
        document.getElementById('empty-state').textContent = 'Error: ' + e.message;
      }
    }

    function changePage(page) {
      currentPage = page;
      loadOrders();
    }

    loadOrders();
  </script>
</AdminLayout>
