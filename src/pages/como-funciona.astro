---
import BaseLayout from '../layouts/BaseLayout.astro';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Cómo funciona Trust Para Todos',
  serviceType: 'Trust creation and estate planning process',
  description: '5 pasos simples para proteger tu patrimonio: evaluación gratuita, recomendación, compra en línea, documentos y notaría, trust activo. Todo en español, 100% en línea, 3-5 días hábiles.',
  provider: {
    '@type': 'Organization',
    name: 'Trust Para Todos',
    url: 'https://trustparatodos.com'
  },
  areaServed: 'United States',
  offers: {
    '@type': 'Offer',
    price: '997',
    priceCurrency: 'USD'
  }
};
---

<BaseLayout title="Cómo funciona — Trust Para Todos" description="5 pasos simples para proteger tu patrimonio. Desde tu evaluación gratuita hasta recibir tu trust completo. Todo en español." canonicalPath="/como-funciona" jsonLd={serviceSchema}>

  <section class="hero" style="padding: 60px 20px;">
    <h1>Cómo funciona</h1>
    <p>5 pasos simples. Todo en línea. En español.</p>
  </section>

  <section class="section">
    <div class="container">
      <div class="steps">
        <div class="step">
          <h3>Tu evaluación gratuita</h3>
          <p>Completas un cuestionario de 3 minutos. Te hacemos preguntas básicas sobre tu situación familiar y tus bienes.</p>
        </div>
        <div class="step">
          <h3>Recibes tu recomendación</h3>
          <p>Te decimos qué paquete es mejor para ti. Trust básico ($997) o con protección de seguro de vida (+$497).</p>
        </div>
        <div class="step">
          <h3>Compras en línea</h3>
          <p>Pagas con tarjeta, OXXO o SPEI. Usamos Stripe — tu pago está 100% seguro.</p>
        </div>
        <div class="step">
          <h3>Documentos y notaría</h3>
          <p>Recibes tus documentos en 24-48 horas. Agenda tu cita notarial en línea (15 minutos, notario bilingüe).</p>
        </div>
        <div class="step">
          <h3>Trust activo y protegido</h3>
          <p>Recibes tu EIN del IRS, tu trust está oficialmente activo. Accede a tu dashboard, tu curso y tu plataforma TrustOffice.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container" style="text-align: center;">
      <h2>¿Cuánto tiempo toma?</h2>
      <div class="cards" style="max-width: 800px; margin: 0 auto;">
        <div class="card">
          <div class="card-icon">⏱️</div>
          <h3>De principio a fin: 3-5 días hábiles</h3>
          <p>Evaluación (3 min) → Compra (2 min) → Documentos listos (24-48h) → Notaría (15 min) → EIN (1-2 días).</p>
        </div>
        <div class="card">
          <div class="card-icon">📱</div>
          <h3>100% en línea</h3>
          <p>Todo se hace desde tu celular o computadora. Nunca tienes que ir a una oficina.</p>
        </div>
      </div>
      <a href="/evaluacion" class="btn btn-primary btn-lg" style="margin-top: 32px;">Comenzar ahora</a>
    </div>
  </section>

</BaseLayout>