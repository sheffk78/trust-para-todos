---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Tu Evaluación Gratuita — Trust Para Todos" description="Descubre en 3 minutos si un trust es adecuado para ti. Evaluación gratuita y sin compromiso.">

<style>
  /* === Multi-Step Form === */
  .eval-section {
    padding: 60px 0 100px;
  }
  .eval-container {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Progress Bar */
  .progress-bar {
    display: flex;
    justify-content: space-between;
    margin-bottom: 48px;
    position: relative;
  }
  .progress-bar::before {
    content: '';
    position: absolute;
    top: 14px;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--cream-dark);
    z-index: 0;
  }
  .progress-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    position: relative;
    z-index: 1;
  }
  .progress-dot {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: var(--white);
    border: 2px solid var(--cream-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
    transition: all 0.4s;
  }
  .progress-step.active .progress-dot {
    background: var(--teal);
    border-color: var(--teal);
    color: var(--white);
  }
  .progress-step.completed .progress-dot {
    background: var(--teal);
    border-color: var(--teal);
    color: var(--white);
  }
  .progress-step.completed .progress-dot::after {
    content: '✓';
    font-size: 0.8rem;
  }
  .progress-step.completed .progress-dot span { display: none; }
  .progress-label {
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-align: center;
  }
  .progress-step.active .progress-label { color: var(--teal); font-weight: 600; }
  .progress-step.completed .progress-label { color: var(--teal); }

  /* Form Steps */
  .form-step {
    display: none;
    animation: fadeIn 0.4s ease;
  }
  .form-step.active { display: block; }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .step-header {
    text-align: center;
    margin-bottom: 40px;
  }
  .step-header h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 2rem;
    color: var(--dark);
    margin-bottom: 8px;
  }
  .step-header p {
    color: var(--text-muted);
    font-size: 1rem;
    max-width: 480px;
    margin: 0 auto;
  }

  /* Form Groups */
  .form-group {
    margin-bottom: 24px;
  }
  .form-group label {
    display: block;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--dark);
    margin-bottom: 6px;
  }
  .form-group .hint {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 8px;
  }
  .form-group input,
  .form-group select {
    width: 100%;
    padding: 14px 16px;
    border: 1.5px solid var(--cream-dark);
    border-radius: var(--radius-sm);
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    color: var(--dark);
    background: var(--white);
    transition: border-color 0.2s;
    outline: none;
  }
  .form-group input:focus,
  .form-group select:focus {
    border-color: var(--teal);
    box-shadow: 0 0 0 3px rgba(4, 112, 126, 0.1);
  }
  .form-group .input-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .form-group .input-row-3 {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 16px;
  }

  /* Radio Cards */
  .radio-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .radio-card {
    position: relative;
    cursor: pointer;
  }
  .radio-card input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .radio-card-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 24px 16px;
    border: 1.5px solid var(--cream-dark);
    border-radius: var(--radius);
    background: var(--white);
    transition: all 0.2s;
    text-align: center;
  }
  .radio-card input:checked + .radio-card-content {
    border-color: var(--teal);
    background: var(--teal-light);
    box-shadow: 0 0 0 3px rgba(4, 112, 126, 0.15);
  }
  .radio-card:hover .radio-card-content {
    border-color: var(--teal);
  }
  .radio-card .radio-emoji {
    font-size: 2rem;
    line-height: 1;
  }
  .radio-card .radio-title {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--dark);
  }
  .radio-card .radio-desc {
    font-size: 0.8rem;
    color: var(--text-muted);
    line-height: 1.4;
  }

  /* Navigation Buttons */
  .step-nav {
    display: flex;
    justify-content: space-between;
    margin-top: 40px;
    gap: 16px;
  }
  .step-nav .btn {
    min-width: 160px;
  }
  .btn-back {
    background: var(--white);
    color: var(--text-body);
    border: 1.5px solid var(--cream-dark);
  }
  .btn-back:hover {
    border-color: var(--teal);
    color: var(--teal);
    transform: none;
    box-shadow: none;
  }

  /* Summary Card */
  .summary-card {
    background: var(--white);
    border: 1px solid var(--cream-dark);
    border-radius: var(--radius);
    padding: 32px;
    margin-bottom: 24px;
  }
  .summary-card h3 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.2rem;
    color: var(--teal);
    margin-bottom: 16px;
  }
  .summary-row {
    display: flex;
    justify-content: space-between;
    padding: 10px 0;
    border-bottom: 1px solid var(--cream-dark);
    font-size: 0.9rem;
  }
  .summary-row:last-child { border-bottom: none; }
  .summary-row .label { color: var(--text-muted); }
  .summary-row .value { font-weight: 600; color: var(--dark); }

  /* Plan Cards */
  .plan-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 32px;
  }
  .plan-card {
    position: relative;
    cursor: pointer;
  }
  .plan-card input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .plan-card-content {
    padding: 32px 24px;
    border: 1.5px solid var(--cream-dark);
    border-radius: var(--radius);
    background: var(--white);
    transition: all 0.2s;
    text-align: center;
  }
  .plan-card input:checked + .plan-card-content {
    border-color: var(--teal);
    box-shadow: 0 0 0 3px rgba(4, 112, 126, 0.15);
  }
  .plan-card.recommended .plan-card-content {
    border-color: var(--terracotta);
    position: relative;
  }
  .plan-card.recommended input:checked + .plan-card-content {
    border-color: var(--terracotta);
    box-shadow: 0 0 0 3px rgba(221, 112, 84, 0.2);
  }
  .plan-badge {
    display: inline-block;
    background: var(--terracotta);
    color: var(--white);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 4px 12px;
    border-radius: 100px;
    margin-bottom: 12px;
  }
  .plan-card-content h3 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.3rem;
    color: var(--dark);
    margin-bottom: 4px;
  }
  .plan-price {
    font-size: 2rem;
    font-weight: 700;
    color: var(--teal);
    margin-bottom: 4px;
  }
  .plan-price span {
    font-size: 1rem;
    font-weight: 400;
    color: var(--text-muted);
  }
  .plan-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 16px;
    line-height: 1.5;
  }
  .plan-features {
    list-style: none;
    text-align: left;
    font-size: 0.85rem;
  }
  .plan-features li {
    padding: 6px 0;
    color: var(--text-body);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .plan-features li::before {
    content: '✓';
    color: var(--teal);
    font-weight: 700;
  }

  /* Loading State */
  .loading-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.4);
    z-index: 1000;
    align-items: center;
    justify-content: center;
  }
  .loading-overlay.active { display: flex; }
  .loading-card {
    background: var(--white);
    border-radius: var(--radius);
    padding: 48px;
    text-align: center;
    max-width: 400px;
    box-shadow: var(--shadow-lg);
  }
  .loading-spinner {
    width: 48px;
    height: 48px;
    border: 3px solid var(--cream-dark);
    border-top-color: var(--teal);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    margin: 0 auto 20px;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  .loading-card h3 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.2rem;
    color: var(--dark);
    margin-bottom: 8px;
  }
  .loading-card p {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  /* Error State */
  .error-message {
    display: none;
    background: #fef2f2;
    border: 1px solid #fecaca;
    color: #991b1b;
    padding: 16px;
    border-radius: var(--radius-sm);
    margin-bottom: 20px;
    font-size: 0.9rem;
  }
  .error-message.active { display: block; }

  /* Responsive */
  @media (max-width: 640px) {
    .radio-grid { grid-template-columns: 1fr; }
    .plan-cards { grid-template-columns: 1fr; }
    .form-group .input-row { grid-template-columns: 1fr; }
    .form-group .input-row-3 { grid-template-columns: 1fr; }
    .step-nav { flex-direction: column; }
    .step-nav .btn { width: 100%; }
    .progress-label { display: none; }
  }
</style>

<section class="eval-section">
  <div class="eval-container">

    <!-- Progress Bar -->
    <div class="progress-bar" id="progress-bar">
      <div class="progress-step active" data-step="1">
        <div class="progress-dot"><span>1</span></div>
        <span class="progress-label">Tú</span>
      </div>
      <div class="progress-step" data-step="2">
        <div class="progress-dot"><span>2</span></div>
        <span class="progress-label">Familia</span>
      </div>
      <div class="progress-step" data-step="3">
        <div class="progress-dot"><span>3</span></div>
        <span class="progress-label">Patrimonio</span>
      </div>
      <div class="progress-step" data-step="4">
        <div class="progress-dot"><span>4</span></div>
        <span class="progress-label">Plan</span>
      </div>
      <div class="progress-step" data-step="5">
        <div class="progress-dot"><span>5</span></div>
        <span class="progress-label">Confirmar</span>
      </div>
    </div>

    <!-- Error Message -->
    <div class="error-message" id="error-message"></div>

    <!-- Step 1: About You -->
    <div class="form-step active" data-step="1">
      <div class="step-header">
        <h2>Cuéntanos de ti</h2>
        <p>Esta información nos ayuda a determinar el tipo de trust que necesitas.</p>
      </div>

      <div class="form-group">
        <label for="name">Tu nombre completo</label>
        <input type="text" id="name" placeholder="Ej: Juan Carlos Rodríguez" />
      </div>

      <div class="form-group">
        <label for="spouse_name">Nombre de tu cónyuge (si aplica)</label>
        <input type="text" id="spouse_name" placeholder="Ej: María Elena Rodríguez" />
        <div class="hint">Si estás casado/a, un trust conjunto es la mejor opción.</div>
      </div>

      <div class="form-group">
        <label for="email">Correo electrónico</label>
        <input type="email" id="email" placeholder="ejemplo@correo.com" />
      </div>

      <div class="form-group">
        <label for="phone">Teléfono</label>
        <input type="tel" id="phone" placeholder="(555) 123-4567" />
      </div>

      <div class="form-group">
        <label>¿Eres ciudadano estadounidense o residente permanente?</label>
        <div class="radio-grid">
          <label class="radio-card">
            <input type="radio" name="citizenship" value="citizen" />
            <div class="radio-card-content">
              <div class="radio-emoji">🇺🇸</div>
              <div class="radio-title">Ciudadano o Residente</div>
              <div class="radio-desc">Green card, visa de trabajo, o ciudadano</div>
            </div>
          </label>
          <label class="radio-card">
            <input type="radio" name="citizenship" value="non_resident" />
            <div class="radio-card-content">
              <div class="radio-emoji">🌎</div>
              <div class="radio-title">No residente</div>
              <div class="radio-desc">Visa de turista o sin estatus legal</div>
            </div>
          </label>
        </div>
      </div>

      <div class="step-nav">
        <div></div>
        <button class="btn btn-primary" onclick="nextStep(1)">Continuar →</button>
      </div>
    </div>

    <!-- Step 2: Family -->
    <div class="form-step" data-step="2">
      <div class="step-header">
        <h2>Tu familia</h2>
        <p>Esto determina cómo se distribuirán tus bienes.</p>
      </div>

      <div class="form-group">
        <label>Estado civil</label>
        <div class="radio-grid">
          <label class="radio-card">
            <input type="radio" name="marital_status" value="married" />
            <div class="radio-card-content">
              <div class="radio-emoji">💑</div>
              <div class="radio-title">Casado/a</div>
              <div class="radio-desc">Con o sin hijos</div>
            </div>
          </label>
          <label class="radio-card">
            <input type="radio" name="marital_status" value="single" />
            <div class="radio-card-content">
              <div class="radio-emoji">👤</div>
              <div class="radio-title">Soltero/a</div>
              <div class="radio-desc">Divorciado, viudo, o nunca casado</div>
            </div>
          </label>
        </div>
      </div>

      <div class="form-group">
        <label for="children">¿Cuántos hijos tienes?</label>
        <select id="children">
          <option value="0">Ninguno</option>
          <option value="1" selected>1</option>
          <option value="2">2</option>
          <option value="3">3</option>
          <option value="4">4</option>
          <option value="5">5 o más</option>
        </select>
      </div>

      <div class="form-group" id="children-names-group" style="display:block;">
        <label for="children_names">Nombres de tus hijos</label>
        <input type="text" id="children_names" placeholder="Ej: Carlos Jr., Ana, Luis" />
        <div class="hint">Separa los nombres con coma.</div>
      </div>

      <div class="step-nav">
        <button class="btn btn-back" onclick="prevStep(2)">← Atrás</button>
        <button class="btn btn-primary" onclick="nextStep(2)">Continuar →</button>
      </div>
    </div>

    <!-- Step 3: Assets -->
    <div class="form-step" data-step="3">
      <div class="step-header">
        <h2>Tu patrimonio</h2>
        <p>Selecciona los bienes que tienes en Estados Unidos.</p>
      </div>

      <div class="form-group">
        <label>¿Tienes una casa en Estados Unidos?</label>
        <div class="radio-grid">
          <label class="radio-card">
            <input type="radio" name="has_home" value="yes" />
            <div class="radio-card-content">
              <div class="radio-emoji">🏠</div>
              <div class="radio-title">Sí, tengo casa</div>
              <div class="radio-desc">Propia o en co-propiedad</div>
            </div>
          </label>
          <label class="radio-card">
            <input type="radio" name="has_home" value="no" />
            <div class="radio-card-content">
              <div class="radio-emoji">🏢</div>
              <div class="radio-title">No, rento</div>
              <div class="radio-desc">Vivo en alquiler</div>
            </div>
          </label>
        </div>
      </div>

      <div class="form-group" id="home-value-group" style="display:none;">
        <label for="home_value">Valor aproximado de tu casa</label>
        <select id="home_value">
          <option value="under_250k">Menos de $250,000</option>
          <option value="250k_500k">$250,000 - $500,000</option>
          <option value="500k_1m">$500,000 - $1,000,000</option>
          <option value="over_1m">Más de $1,000,000</option>
        </select>
      </div>

      <div class="form-group">
        <label>¿Tienes cuentas de banco o inversiones?</label>
        <div class="radio-grid">
          <label class="radio-card">
            <input type="radio" name="has_accounts" value="yes" />
            <div class="radio-card-content">
              <div class="radio-emoji">🏦</div>
              <div class="radio-title">Sí</div>
              <div class="radio-desc">Cuentas de cheques, ahorros, o inversiones</div>
            </div>
          </label>
          <label class="radio-card">
            <input type="radio" name="has_accounts" value="no" />
            <div class="radio-card-content">
              <div class="radio-emoji">💵</div>
              <div class="radio-title">No</div>
              <div class="radio-desc">Solo efectivo</div>
            </div>
          </label>
        </div>
      </div>

      <div class="form-group">
        <label>¿Tienes propiedades o cuentas en México u otro país?</label>
        <div class="radio-grid">
          <label class="radio-card">
            <input type="radio" name="has_foreign" value="yes" />
            <div class="radio-card-content">
              <div class="radio-emoji">🌍</div>
              <div class="radio-title">Sí</div>
              <div class="radio-desc">Casa, terreno, o cuentas en el extranjero</div>
            </div>
          </label>
          <label class="radio-card">
            <input type="radio" name="has_foreign" value="no" />
            <div class="radio-card-content">
              <div class="radio-emoji">🇺🇸</div>
              <div class="radio-title">No</div>
              <div class="radio-desc">Todo está en Estados Unidos</div>
            </div>
          </label>
        </div>
      </div>

      <div class="step-nav">
        <button class="btn btn-back" onclick="prevStep(3)">← Atrás</button>
        <button class="btn btn-primary" onclick="nextStep(3)">Continuar →</button>
      </div>
    </div>

    <!-- Step 4: Choose Plan -->
    <div class="form-step" data-step="4">
      <div class="step-header">
        <h2>Elige tu plan</h2>
        <p>Selecciona el nivel de protección que necesitas.</p>
      </div>

      <div class="plan-cards">
        <label class="plan-card">
          <input type="radio" name="plan" value="base" />
          <div class="plan-card-content">
            <h3>Trust Para Todos</h3>
            <div class="plan-price">$997 <span>/ único</span></div>
            <p class="plan-desc">Protección esencial para tu familia</p>
            <ul class="plan-features">
              <li>Trust revocable personalizado</li>
              <li>Certificado de Trust</li>
              <li>Asignación de bienes</li>
              <li>Guía explicativa en español</li>
              <li>Panel de control</li>
              <li>Notaría virtual</li>
            </ul>
          </div>
        </label>

        <label class="plan-card recommended">
          <input type="radio" name="plan" value="complete" checked />
          <div class="plan-card-content">
            <div class="plan-badge">Recomendado</div>
            <h3>Paquete Completo</h3>
            <div class="plan-price">$1,497 <span>/ único</span></div>
            <p class="plan-desc">Protección total para tu patrimonio</p>
            <ul class="plan-features">
              <li>Todo lo del plan Trust Para Todos</li>
              <li>Testamento (Pour-Over Will)</li>
              <li>Poder notarial financiero</li>
              <li>Directiva de atención médica</li>
              <li>Trámite de EIN ante el IRS</li>
              <li>Curso Trustee 101 incluido</li>
              <li>6 meses de TrustOffice gratis</li>
            </ul>
          </div>
        </label>
      </div>

      <div class="step-nav">
        <button class="btn btn-back" onclick="prevStep(4)">← Atrás</button>
        <button class="btn btn-primary" onclick="nextStep(4)">Continuar →</button>
      </div>
    </div>

    <!-- Step 5: Confirm & Submit -->
    <div class="form-step" data-step="5">
      <div class="step-header">
        <h2>Confirma tu información</h2>
        <p>Revisa que todo esté correcto antes de continuar.</p>
      </div>

      <div class="summary-card">
        <h3>Tu información</h3>
        <div class="summary-row">
          <span class="label">Nombre</span>
          <span class="value" id="summary-name">—</span>
        </div>
        <div class="summary-row">
          <span class="label">Cónyuge</span>
          <span class="value" id="summary-spouse">—</span>
        </div>
        <div class="summary-row">
          <span class="label">Correo</span>
          <span class="value" id="summary-email">—</span>
        </div>
        <div class="summary-row">
          <span class="label">Estado civil</span>
          <span class="value" id="summary-marital">—</span>
        </div>
        <div class="summary-row">
          <span class="label">Hijos</span>
          <span class="value" id="summary-children">—</span>
        </div>
        <div class="summary-row">
          <span class="label">Ciudadanía</span>
          <span class="value" id="summary-citizenship">—</span>
        </div>
        <div class="summary-row">
          <span class="label">Casa en EE.UU.</span>
          <span class="value" id="summary-home">—</span>
        </div>
        <div class="summary-row">
          <span class="label">Plan</span>
          <span class="value" id="summary-plan">—</span>
        </div>
        <div class="summary-row">
          <span class="label">Total</span>
          <span class="value" id="summary-total" style="font-size:1.2rem; color:var(--teal);">—</span>
        </div>
      </div>

      <div class="step-nav">
        <button class="btn btn-back" onclick="prevStep(5)">← Editar</button>
        <button class="btn btn-primary btn-lg" onclick="submitForm()" style="flex:1;">
          Ir a pago seguro →
        </button>
      </div>
    </div>

  </div>
</section>

<!-- Loading Overlay -->
<div class="loading-overlay" id="loading-overlay">
  <div class="loading-card">
    <div class="loading-spinner"></div>
    <h3>Preparando tu orden...</h3>
    <p>Estamos procesando tu información. Serás redirigido al pago seguro.</p>
  </div>
</div>

<script>
  let currentStep = 1;
  const totalSteps = 5;

  function showError(msg) {
    const el = document.getElementById('error-message');
    el.textContent = msg;
    el.classList.add('active');
    setTimeout(() => el.classList.remove('active'), 5000);
  }

  function updateProgress(step) {
    document.querySelectorAll('.progress-step').forEach(el => {
      const s = parseInt(el.dataset.step);
      el.classList.toggle('active', s === step);
      el.classList.toggle('completed', s < step);
    });
  }

  function showStep(step) {
    document.querySelectorAll('.form-step').forEach(el => {
      el.classList.toggle('active', parseInt(el.dataset.step) === step);
    });
    updateProgress(step);
    currentStep = step;
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function nextStep(from) {
    // Validate current step
    if (from === 1) {
      const name = document.getElementById('name').value.trim();
      const email = document.getElementById('email').value.trim();
      const citizenship = document.querySelector('input[name="citizenship"]:checked');
      if (!name) { showError('Por favor ingresa tu nombre.'); return; }
      if (!email) { showError('Por favor ingresa tu correo electrónico.'); return; }
      if (!email.includes('@')) { showError('Correo electrónico no válido.'); return; }
      if (!citizenship) { showError('Selecciona tu estatus migratorio.'); return; }
    }
    if (from === 2) {
      const marital = document.querySelector('input[name="marital_status"]:checked');
      if (!marital) { showError('Selecciona tu estado civil.'); return; }
    }
    if (from === 3) {
      const home = document.querySelector('input[name="has_home"]:checked');
      if (!home) { showError('Indica si tienes casa en Estados Unidos.'); return; }
    }
    if (from === 4) {
      const plan = document.querySelector('input[name="plan"]:checked');
      if (!plan) { showError('Selecciona un plan.'); return; }
    }

    if (from === 4) {
      // Populate summary
      document.getElementById('summary-name').textContent = document.getElementById('name').value.trim();
      document.getElementById('summary-spouse').textContent = document.getElementById('spouse_name').value.trim() || 'No aplica';
      document.getElementById('summary-email').textContent = document.getElementById('email').value.trim();
      document.getElementById('summary-marital').textContent =
        document.querySelector('input[name="marital_status"]:checked')?.value === 'married' ? 'Casado/a' : 'Soltero/a';
      document.getElementById('summary-children').textContent =
        document.getElementById('children_names').value.trim() || 'Ninguno';
      document.getElementById('summary-citizenship').textContent =
        document.querySelector('input[name="citizenship"]:checked')?.value === 'citizen' ? 'Ciudadano o Residente' : 'No residente';
      document.getElementById('summary-home').textContent =
        document.querySelector('input[name="has_home"]:checked')?.value === 'yes' ? 'Sí' : 'No';
      const planVal = document.querySelector('input[name="plan"]:checked')?.value;
      document.getElementById('summary-plan').textContent = planVal === 'base' ? 'Trust Para Todos' : 'Paquete Completo';
      document.getElementById('summary-total').textContent = planVal === 'base' ? '$997' : '$1,497';
    }

    showStep(from + 1);
  }

  function prevStep(from) {
    showStep(from - 1);
  }

  // Show home value field when "Sí" is selected
  document.querySelectorAll('input[name="has_home"]').forEach(r => {
    r.addEventListener('change', () => {
      document.getElementById('home-value-group').style.display =
        document.querySelector('input[name="has_home"]:checked')?.value === 'yes' ? 'block' : 'none';
    });
  });

  // Submit form
  async function submitForm() {
    const overlay = document.getElementById('loading-overlay');
    overlay.classList.add('active');

    const data = {
      settlor_1_full_name: document.getElementById('name').value.trim(),
      settlor_2_full_name: document.getElementById('spouse_name').value.trim() || '',
      email: document.getElementById('email').value.trim(),
      phone: document.getElementById('phone').value.trim(),
      citizenship: document.querySelector('input[name="citizenship"]:checked')?.value,
      marital_status: document.querySelector('input[name="marital_status"]:checked')?.value,
      number_of_children: parseInt(document.getElementById('children').value),
      children_names: document.getElementById('children_names').value.trim(),
      has_home: document.querySelector('input[name="has_home"]:checked')?.value,
      home_value: document.getElementById('home_value').value,
      has_accounts: document.querySelector('input[name="has_accounts"]:checked')?.value,
      has_foreign: document.querySelector('input[name="has_foreign"]:checked')?.value,
      plan_type: document.querySelector('input[name="plan"]:checked')?.value,
    };

    try {
      const res = await fetch('/api/orders/create-direct', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (!res.ok) {
        const err = await res.json();
        throw new Error(err.detail || err.error || 'Error al procesar');
      }

      const result = await res.json();

      // Redirect to panel with the order
      if (result.panel_url) {
        window.location.href = result.panel_url;
      } else if (result.checkout_url) {
        window.location.href = result.checkout_url;
      } else if (result.url) {
        window.location.href = result.url;
      } else {
        window.location.href = '/panel?email=' + encodeURIComponent(data.email);
      }
    } catch (e) {
      overlay.classList.remove('active');
      showError('Error: ' + e.message + '. Intenta de nuevo.');
    }
  }
</script>

</BaseLayout>
