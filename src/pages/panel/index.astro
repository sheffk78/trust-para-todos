---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Mi Panel — Trust Para Todos" description="Sigue el estado de tu trust, descarga tus documentos y administra tu protección.">

  <section class="hero" style="padding: 40px 20px;">
    <h1>Mi Panel</h1>
    <p>Aquí puedes ver el estado de tu trust y seguir tu progreso.</p>
  </section>

  <section class="section">
    <div class="container" style="max-width: 700px; margin: 0 auto;">

      <div style="background: var(--white); padding: 32px; border-radius: var(--radius); box-shadow: var(--shadow);">
        <h2 style="font-size: 1.2rem; margin-bottom: 24px;">Estado de tu Trust</h2>

        <div class="status-tracker">
          <div class="status-step completed">
            <div class="status-dot"></div>
            <div>
              <strong>🟢 Recibido</strong>
              <p style="font-size: 0.85rem; color: var(--gray);">Tu pedido ha sido recibido. Estamos procesándolo.</p>
            </div>
          </div>
          <div class="status-step active">
            <div class="status-dot"></div>
            <div>
              <strong>🟡 En proceso</strong>
              <p style="font-size: 0.85rem; color: var(--gray);">Tus documentos están siendo preparados.</p>
            </div>
          </div>
          <div class="status-step">
            <div class="status-dot"></div>
            <div>
              <strong>🔵 Listo para notario</strong>
              <p style="font-size: 0.85rem; color: var(--gray);">Tus documentos están listos. Agenda tu cita notarial.</p>
            </div>
          </div>
          <div class="status-step">
            <div class="status-dot"></div>
            <div>
              <strong>🟢 Completado</strong>
              <p style="font-size: 0.85rem; color: var(--gray);">Todo listo. Tu trust está activo y protegido.</p>
            </div>
          </div>
        </div>
      </div>

      <div style="margin-top: 24px; display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
        <div style="background: var(--white); padding: 24px; border-radius: var(--radius); box-shadow: var(--shadow); text-align: center;">
          <div style="font-size: 2rem; margin-bottom: 8px;">📄</div>
          <h3 style="font-size: 1rem; margin-bottom: 8px;">Mis Documentos</h3>
          <p style="font-size: 0.85rem; color: var(--gray);">Descarga tus documentos cuando estén listos.</p>
        </div>
        <div style="background: var(--white); padding: 24px; border-radius: var(--radius); box-shadow: var(--shadow); text-align: center;">
          <div style="font-size: 2rem; margin-bottom: 8px;">📅</div>
          <h3 style="font-size: 1rem; margin-bottom: 8px;">Agendar Notaría</h3>
          <p style="font-size: 0.85rem; color: var(--gray);">Agenda tu cita notarial virtual de 15 minutos.</p>
        </div>
        <div style="background: var(--white); padding: 24px; border-radius: var(--radius); box-shadow: var(--shadow); text-align: center;">
          <div style="font-size: 2rem; margin-bottom: 8px;">🎓</div>
          <h3 style="font-size: 1rem; margin-bottom: 8px;">Curso Trustee 101</h3>
          <p style="font-size: 0.85rem; color: var(--gray);">Aprende a usar y administrar tu trust.</p>
        </div>
        <div style="background: var(--white); padding: 24px; border-radius: var(--radius); box-shadow: var(--shadow); text-align: center;">
          <div style="font-size: 2rem; margin-bottom: 8px;">💬</div>
          <h3 style="font-size: 1rem; margin-bottom: 8px;">Soporte</h3>
          <p style="font-size: 0.85rem; color: var(--gray);">¿Tienes preguntas? Escríbenos.</p>
        </div>
      </div>

      <div style="text-align: center; margin-top: 32px;">
        <a href="https://wa.me/18001234567" class="btn btn-teal">💬 ¿Necesitas ayuda? WhatsApp</a>
      </div>

    </div>
  </section>

</BaseLayout>